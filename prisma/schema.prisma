// ============================================================
// Prisma Schema — ERP / CRM  (Optimized)
// Compatible with PostgreSQL (prod) / SQLite (dev)
//
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // Switch to "sqlite" for local dev
}

// ============================================================
// Enums
// ============================================================

// [CHANGE 8] Was a raw String — typos like "bhd" caused silent
// document corruption. Enum enforces valid ISO 4217 codes.
enum CurrencyCode {
  BHD
  USD
  EUR
  GBP
  SAR
  AED
  KWD
  OMR
  QAR
  EGP
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

enum ItemType {
  PRODUCT // Physical goods — tracked in stock
  SERVICE // Intangible — no stock tracking
}

enum InvoiceStatus {
  DRAFT // initial state can generate quotation
  IN_PROGRESS // when the invoice is created
  SENT // when the invoice is sent to the customer
  COMPLETED // when the invoice is completed
  CANCELLED // when the invoice is cancelled
  DELETED // when the invoice is deleted
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  CHEQUE
  OTHER
}

enum PurchaseStatus {
  DRAFT
  ORDERED
  PARTIAL_RECEIVED
  RECEIVED
  CANCELLED
}

// ============================================================
// Organization (multi-tenancy root)
// ============================================================

model Organization {
  id      String  @id @default(cuid())
  name    String
  logo    String?
  address String?
  website String?
  taxId   String? // VAT / CR number shown on documents

  slug String @unique

  // [CHANGE 8] Was String — now typed CurrencyCode enum
  currency CurrencyCode @default(BHD)

  // Default payment terms in days (e.g. 30 → Net 30)
  paymentTermsDays Int @default(30)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 User[]
  userOrganizationRoles UserOrganizationRole[]
  customers             Customer[]
  jobs                  Job[]
  purchases             Purchase[]
  invoices              Invoice[]
  items                 Item[]
  itemCategories        itemCategory[]
}

// ============================================================
// Auth
// ============================================================

model User {
  id            String  @id @default(cuid())
  name          String
  email         String  @unique
  emailVerified Boolean @default(false)
  image         String?

  firstName String?
  lastName  String?
  isActive  Boolean @default(true)
  locale    String  @default("en")

  // [CHANGE 7] Global role kept only for SUPER_ADMIN.
  // Per-org roles now live in UserOrganizationRole.
  role Role @default(USER)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts              Account[]
  sessions              Session[]
  invoices              Invoice[]
  userOrganizationRoles UserOrganizationRole[]

  @@index([email])
  @@index([organizationId])
  @@map("user")
}

// [CHANGE 7] New junction model — replaces the single Role enum
// on User. Each row grants a user a role within one org.
// A SUPER_ADMIN can still be checked via User.role globally.
model UserOrganizationRole {
  id   String @id @default(cuid())
  role Role   @default(USER)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, organizationId]) // One role per user per org
  @@index([organizationId])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  scope                 String?
  password              String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Jwks {
  id         String    @id @default(cuid())
  publicKey  String
  privateKey String
  createdAt  DateTime
  expiresAt  DateTime?

  @@map("jwks")
}

// ============================================================
// Customers
// ============================================================

model Customer {
  id    String  @id @default(cuid())
  name  String
  phone String?
  email String?

  address  String?
  taxId    String? // Customer's VAT number
  notes    String?
  isActive Boolean @default(true)

  // [CHANGE 14] Soft delete — aligned with Item/Supplier pattern
  deletedAt DateTime?

  // [CHANGE 1] Was Int — BigInt prevents overflow on high-value accounts
  creditLimit BigInt @default(0)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  jobs      Job[]
  purchases Purchase[]
  invoices  Invoice[]
  payments  Payment[]

  @@index([organizationId])
  @@index([email])
  @@index([deletedAt])
  // [CHANGE 12] Composite — "active customers for org X" is a common lookup
  @@index([organizationId, isActive])
}

// ============================================================
// Jobs
// ============================================================
enum JobStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model Job {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      JobStatus @default(NOT_STARTED)

  startDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  customerId     String
  customer       Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  invoices       Invoice[]
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?

  @@index([customerId])
  @@index([status])
}

model Purchase {
  id         String @id @default(cuid())
  customerId String

  // What you did / what it costs you
  title    String
  details  String?
  quantity Decimal @default(1)
  unitCost BigInt // your cost basis

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  invoiceLines   InvoiceLine[]
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?

  @@index([customerId])
}

model Invoice {
  id String @id @default(cuid())

  status InvoiceStatus @default(IN_PROGRESS)

  invoiceNumber String?  @unique
  currency      String   @default("BHD")
  invoiceDate   DateTime @default(now())

  notes String?

  subtotal      BigInt
  taxTotal      BigInt
  discountTotal BigInt
  total         BigInt

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  jobId      String?
  job        Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)

  lines             InvoiceLine[]
  payments          Payment[]
  organization      Organization?      @relation(fields: [organizationId], references: [id])
  organizationId    String?
  user              User?              @relation(fields: [userId], references: [id])
  userId            String?
  invoiceLineGroups InvoiceLineGroup[]

  @@index([customerId])
  @@index([status])
  @@index([invoiceDate])
}

model InvoiceLine {
  id String @id @default(cuid())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  // Quantities and pricing on the sale side
  description   String
  quantity      BigInt // e.g. hours, units
  unitSalePrice BigInt
  lineTotal     BigInt

  purchaseId String? // null when MANUAL
  purchase   Purchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)

  createdAt          DateTime          @default(now())
  itemId             String?
  invoiceLineGroup   InvoiceLineGroup? @relation(fields: [invoiceLineGroupId], references: [id])
  invoiceLineGroupId String?

  @@index([invoiceId])
  @@index([purchaseId])
}

model InvoiceLineGroup {
  id        String        @id @default(cuid())
  title     String
  invoiceId String
  invoice   Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  lines     InvoiceLine[]
}

model Payment {
  id String @id @default(cuid())

  amount    BigInt
  method    PaymentMethod @default(CASH)
  reference String? // external txn id
  paidAt    DateTime      @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerId String
  invoiceId  String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([customerId])
}

model Item {
  id          String   @id @default(cuid())
  sku         String?  @unique
  barcode     String?  @unique
  name        String
  description String?
  type        ItemType @default(PRODUCT)

  // For PRODUCTS, this is the current stock level.
  // For SERVICES, this can be null or ignored.
  stockQuantity BigInt?

  purchasePrice BigInt @default(0) // your cost basis
  salesPrice    BigInt @default(0) // what you charge customers

  categoryId String?
  category   itemCategory? @relation(fields: [categoryId], references: [id])

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?
}

model itemCategory {
  id    String  @id @default(cuid())
  name  String  @unique
  color String? // for UI tagging
  icon  String? // e.g. "box", "tool", "service" — for UI

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?
  items          Item[]
}
