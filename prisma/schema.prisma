// Prisma schema — compatible with both SQLite (dev) and PostgreSQL (prod)
// Switch provider via DATABASE_PROVIDER env var or by editing the datasource block.
// All monetary values are stored as Int in the smallest currency unit (e.g. fils for BHD, cents for USD).

generator client {
  provider = "prisma-client-js"
}

// -------------------------------------------------------
// For SQLite (local dev):
//   provider = "sqlite"
//   url      = "file:./dev.db"
//
// For PostgreSQL (production):
//   provider = "postgresql"
//   url      = env("DATABASE_URL")
// -------------------------------------------------------
datasource db {
  provider = "sqlite"
}

// ====================================================
// Settings
// ====================================================

model Organization {
  id       Int     @id @default(autoincrement())
  name     String
  logo     String?
  address  String?
  website  String?
  tax      String?
  slug     String  @unique
  currency String  @default("BHD")

  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  users          User[]
  contracts      Contract[]
  invoices       Invoice[]
  customers      Customer[]
  inventoryItems InventoryItem[]
  stocks         Stock[]
  suppliers      Supplier[]
  warehouses     Warehouse[]
  stockItems     StockItem[]
  categories     Category[]
  purchaseOrders PurchaseOrder[]
  stockMovements StockMovement[]
}

// ====================================================
// Auth
// ====================================================

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Custom Fields
  firstName String?
  lastName  String?
  role      Role    @default(USER)
  isActive  Boolean @default(true)
  locale    String  @default("en")

  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  accounts       Account[]
  sessions       Session[]
  invoices       Invoice[]
  stockMovements StockMovement[]

  @@index([email])
  @@index([organizationId])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Jwks {
  id         String    @id
  publicKey  String
  privateKey String
  createdAt  DateTime
  expiresAt  DateTime?

  @@map("jwks")
}

// ====================================================
// Invoices
// ====================================================

enum InvoicePaymentStatus {
  Paid
  Unpaid
  Partial
}

enum PaymentMethod {
  CASH
  TRANSFER
}

model Invoice {
  id            Int                  @id @default(autoincrement())
  date          DateTime?            @default(now())
  description   String?
  paymentStatus InvoicePaymentStatus @default(Unpaid)
  isCompleted   Boolean              @default(false)
  currency      String               @default("BHD")

  /// All totals stored in smallest currency unit (e.g. fils)
  subtotal      Int @default(0)
  discountTotal Int @default(0)
  taxTotal      Int @default(0)
  total         Int @default(0)

  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id])

  userId    String
  createdBy User   @relation(fields: [userId], references: [id])

  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  payments     Payment[]
  invoiceLines InvoiceLine[]

  @@index([customerId])
  @@index([userId])
  @@index([organizationId])
  @@index([isCompleted])
  @@index([paymentStatus])
  @@index([date])
}

model InvoiceLine {
  id            Int     @id @default(autoincrement())
  description   String?
  /// Stored in smallest currency unit (e.g. fils)
  purchasePrice Int
  /// Stored in smallest currency unit (e.g. fils)
  salesPrice    Int
  quantity      Int     @default(1)
  /// Stored in smallest currency unit (e.g. fils)
  total         Int

  inventoryItemId Int?
  itemRef         InventoryItem? @relation(fields: [inventoryItemId], references: [id])

  invoiceId Int?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  isGroup    Boolean       @default(false)
  parentId   Int?
  parentLine InvoiceLine?  @relation("GroupedLines", fields: [parentId], references: [id], onDelete: Cascade)
  childLines InvoiceLine[] @relation("GroupedLines")

  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  @@index([invoiceId])
  @@index([inventoryItemId])
  @@index([parentId])
}

model Payment {
  id        Int           @id @default(autoincrement())
  date      DateTime?     @default(now())
  method    PaymentMethod @default(CASH)
  /// Stored in smallest currency unit (e.g. fils)
  amount    Int
  reference String?
  notes     String?

  invoiceId Int
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  @@index([invoiceId])
}

// ====================================================
// Customers
// ====================================================

model Customer {
  id      Int     @id @default(autoincrement())
  name    String
  phone   String
  address String
  email   String?

  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  invoices Invoice[]

  @@index([organizationId])
}

// ====================================================
// Suppliers Items + Inventory
// ====================================================

model Supplier {
  id          Int     @id @default(autoincrement())
  name        String
  phone       String
  address     String
  email       String?
  contactName String?
  website     String?
  taxId       String?
  notes       String?

  inventoryItems InventoryItem[]

  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt      DateTime?       @default(now())
  updatedAt      DateTime?       @updatedAt
  purchaseOrders PurchaseOrder[]

  @@map("supplier")
}

model InventoryItem {
  id            Int     @id @default(autoincrement())
  code          String?
  name          String
  description   String?
  /// Stored in smallest currency unit (e.g. fils)
  purchasePrice Int
  /// Stored in smallest currency unit (e.g. fils)
  salesPrice    Int
  filePath      String?
  image         String?

  stockItemId Int?
  stockItem   StockItem? @relation(fields: [stockItemId], references: [id])

  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  invoiceLines InvoiceLine[]

  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  supplierId Int?

  @@index([organizationId])
  @@index([code])
  @@map("InventoryItem")
}

model Category {
  id    Int     @id @default(autoincrement())
  name  String
  color String?

  stockItems StockItem[]

  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  @@unique([name, organizationId])
}

// ====================================================
// Stock 
// ====================================================

model Warehouse {
  id      Int     @id @default(autoincrement())
  name    String  @unique
  address String?

  inventory Stock[]

  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId Int?
}

enum ItemType {
  PRODUCT
  SERVICE
}

model StockItem {
  id          Int      @id @default(autoincrement())
  type        ItemType @default(PRODUCT)
  sku         String   @unique
  name        String
  description String?
  image       String?
  barcode     String?
  unit        String   @default("pcs")

  // Prices usually live here as the "Default" price
  purchasePrice Int
  salesPrice    Int

  minStock Int @default(0)

  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id])

  // Relations
  stockEntries   Stock[]
  organization   Organization?   @relation(fields: [organizationId], references: [id])
  organizationId Int?
  purchaseLines  PurchaseLine[]
  stockMovements StockMovement[]
  inventoryItems InventoryItem[]
}

model Stock {
  id       Int     @id @default(autoincrement())
  // Physical properties of this specific batch/location
  quantity Int     @default(0)
  location String? // Specific bin or shelf number

  // Relations - Fixed types to match 'Int' from parent models
  stockItemId Int
  stockItem   StockItem @relation(fields: [stockItemId], references: [id])

  warehouseId Int
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Multi-tenancy
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId Int?

  // Ensures we only have one entry per item per warehouse
  @@unique([stockItemId, warehouseId])
}

enum MovementType {
  INBOUND // From Supplier (Purchase)
  OUTBOUND // To Customer (Sale)
  TRANSFER // Between Warehouses
  ADJUSTMENT // Manual Correction
  WASTAGE // Damaged/Expired
}

model StockMovement {
  id       Int          @id @default(autoincrement())
  type     MovementType
  quantity Int // Positive for additions, negative for deductions

  // The Item being moved
  stockItemId Int
  stockItem   StockItem @relation(fields: [stockItemId], references: [id])

  // Source/Destination tracking
  fromWarehouseId Int?
  toWarehouseId   Int?

  // Reference to business documents
  invoiceId  Int?
  purchaseId Int?

  // Multi-tenancy & Audit
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  notes     String?

  @@index([stockItemId])
  @@index([organizationId])
}

model PurchaseOrder {
  id             Int                  @id @default(autoincrement())
  date           DateTime             @default(now())
  status         InvoicePaymentStatus @default(Unpaid)
  supplierId     Int
  supplier       Supplier             @relation(fields: [supplierId], references: [id])
  organizationId Int
  organization   Organization         @relation(fields: [organizationId], references: [id])

  total      Int     @default(0) // Total in fils
  isReceived Boolean @default(false) // Trigger for stock increment

  lines    PurchaseLine[]
  payments PurchasePayment[]

  @@index([supplierId])
}

model PurchaseLine {
  id              Int           @id @default(autoincrement())
  purchaseOrderId Int
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  stockItemId Int
  stockItem   StockItem @relation(fields: [stockItemId], references: [id])

  quantity      Int
  purchasePrice Int // Cost at time of purchase
  total         Int
}

model PurchasePayment {
  id              Int           @id @default(autoincrement())
  amount          Int
  date            DateTime      @default(now())
  purchaseOrderId Int
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
}

// ====================================================
// Contracts
// ====================================================

model Contract {
  id          String  @id @default(uuid())
  title       String
  description String?
  active      Boolean @default(true)

  /// Stored in smallest currency unit (e.g. fils)
  contractValue Int?
  currency      String @default("BHD")

  startDate   DateTime
  endDate     DateTime
  renewalDate DateTime?

  version Int @default(1)

  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  @@index([organizationId])
  @@index([active])
  @@index([endDate])
}
