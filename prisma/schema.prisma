// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum InvoiceStatus {
  DRAFT
  APPROVED
  PARTIAL
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  TRANSFER
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

model Organization {
  id      Int     @id @default(autoincrement())
  name    String
  logo    String?
  address String?
  country String?
  website String?
  tax     String?

  createdAt DateTime   @default(now())
  updatedAt DateTime?  @updatedAt
  contracts Contract[]
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String
  firstName    String
  lastName     String?
  role         Role    @default(USER)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tokens Tokens[]

  @@index([email])
  @@index([role])
}

model Tokens {
  id         Int       @id @default(autoincrement())
  type       String?
  value      String?   @unique
  expiresAt  DateTime?
  deviceInfo String?
  ipAddress  String?
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @default(now()) @updatedAt
  userId     String
  user       User?     @relation(fields: [userId], references: [id])

  @@index([expiresAt])
}

model InventoryItem {
  id            Int           @id @default(autoincrement())
  code          String?
  name          String
  description   String?
  purchasePrice Int
  salesPrice    Int
  image         String?
  invoice       Invoice?      @relation(fields: [invoiceId], references: [id])
  invoiceId     Int?
  invoiceItems  InvoiceItem[]

  createdAt            DateTime            @default(now())
  updatedAt            DateTime?           @updatedAt
  inventoryItemGroup   InventoryItemGroup? @relation(fields: [inventoryItemGroupId], references: [id])
  inventoryItemGroupId Int?
}

model InventoryItemGroup {
  id    Int             @id @default(autoincrement())
  name  String
  total Int
  items InventoryItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}

model Customer {
  id       Int       @id @default(autoincrement())
  name     String
  phone    String
  address  String
  email    String?
  invoices Invoice[]

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}

model Invoice {
  id          Int            @id @default(autoincrement())
  date        DateTime       @default(now())
  description String?
  customerId  Int?
  tax         Int?
  status      InvoiceStatus? @default(DRAFT)
  currency    String         @default("BHD")

  subtotal      Int?
  total         Int?
  discountTotal Int?
  taxTotal      Int?

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  // Relations
  payments     Payment[]
  invoiceItems InventoryItem[]
  customer     Customer?       @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([status])
}

model InvoiceItem {
  id              Int            @id @default(autoincrement())
  code            String?        @unique
  description     String?
  purchasePrice   Int
  salesPrice      Int
  itemRef         InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  inventoryItemId Int?
  total           Int

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}

model Payment {
  id        Int           @id @default(autoincrement())
  date      DateTime      @default(now()) // Maps to draft.date
  method    PaymentMethod @default(CASH)
  amount    Int // Stored in fils
  reference String? // Cheque # or Transaction ID
  notes     String? // Optional note

  // Relations
  invoiceId Int
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}

model Contract {
  id          String  @id @default(uuid())
  title       String
  description String?
  active      Boolean @default(true)

  // Enterprise Details
  contractValue Int? // in fils
  currency      String @default("BHD")

  // Dates
  startDate   DateTime
  endDate     DateTime
  renewalDate DateTime? // For auto-renewals

  // Versioning and Auditing
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId Int?
}
