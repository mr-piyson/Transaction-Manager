// ============================================================
// Prisma Schema — ERP / CRM  (Optimized)
// Compatible with PostgreSQL (prod) / SQLite (dev)
//
// ============================================================

generator client {
  provider = "prisma-client-js"
}

generator zod {
  provider     = "zod-prisma-types"
  output       = "./generated/zod" // Where the schemas will live
  useDecimalJs = true // Crucial for ERP precision
}

datasource db {
  provider = "sqlite" // Switch to "sqlite" for local dev
}

// ============================================================
// Enums
// ============================================================

// [CHANGE 8] Was a raw String — typos like "bhd" caused silent
// document corruption. Enum enforces valid ISO 4217 codes.
enum CurrencyCode {
  BHD
  USD
  EUR
  GBP
  SAR
  AED
  KWD
  OMR
  QAR
  EGP
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

enum ItemType {
  PRODUCT // Physical goods — tracked in stock
  SERVICE // Intangible — no stock tracking
}

enum InvoiceType {
  INVOICE
  CREDIT_NOTE // Linked to a parent Invoice via parentInvoiceId
  QUOTE // Can be converted to an Invoice
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  CANCELLED
  DELETED
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  CHEQUE
  OTHER
}

enum PurchaseStatus {
  DRAFT
  ORDERED
  PARTIAL_RECEIVED
  RECEIVED
  CANCELLED
}

// [CHANGE 6] New enum — codifies every reason stock quantity changes.
enum StockMovementType {
  SALE_OUTBOUND // Deducted when invoice is confirmed
  PURCHASE_INBOUND // Added when PO is marked received
  RETURN_INBOUND // Customer return adds stock back
  RETURN_OUTBOUND // Stock sent back to supplier
  ADJUSTMENT_UP // Manual positive correction
  ADJUSTMENT_DOWN // Manual negative correction / write-off
  TRANSFER // Movement between warehouses
}

// [CHANGE 17] JobStatus relocated from the bottom orphan position
enum JobStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

// ============================================================
// Organization (multi-tenancy root)
// ============================================================

model Organization {
  id      String  @id @default(cuid())
  name    String
  logo    String?
  address String?
  website String?
  taxId   String? // VAT / CR number shown on documents

  slug String @unique

  // [CHANGE 8] Was String — now typed CurrencyCode enum
  currency CurrencyCode @default(BHD)

  // Default payment terms in days (e.g. 30 → Net 30)
  paymentTermsDays Int @default(30)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 User[]
  userOrganizationRoles UserOrganizationRole[]
  customers             Customer[]
  suppliers             Supplier[]
  items                 Item[]
  warehouses            Warehouse[]
  stocks                Stock[]
  stockMovements        StockMovement[]
  categories            Category[]
  taxRates              TaxRate[]
  invoices              Invoice[]
  purchaseOrders        PurchaseOrder[]
  contracts             Contract[]
  supplierItems         SupplierItem[]
  payments              Payment[]
}

// ============================================================
// Tax Rates
// [CHANGE 3] New model — was magic Int fields scattered across
// InvoiceLine. Centralises VAT/GST management; supports
// multi-rate (standard, zero-rated, exempt) per org.
// ============================================================

model TaxRate {
  id   String @id @default(cuid())
  name String // e.g. "Standard VAT", "Zero-rated", "Exempt"

  // [CHANGE 2] Decimal — e.g. 0.10 = 10%, 0.05 = 5%, 0.00 = exempt
  rate      Decimal
  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items        Item[]
  invoiceLines InvoiceLine[]

  @@unique([name, organizationId])
  @@index([organizationId])
  @@index([isActive, organizationId])
}

// ============================================================
// Auth
// ============================================================

model User {
  id            String  @id @default(cuid())
  name          String
  email         String  @unique
  emailVerified Boolean @default(false)
  image         String?

  firstName String?
  lastName  String?
  isActive  Boolean @default(true)
  locale    String  @default("en")

  // [CHANGE 7] Global role kept only for SUPER_ADMIN.
  // Per-org roles now live in UserOrganizationRole.
  role Role @default(USER)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts              Account[]
  sessions              Session[]
  invoices              Invoice[]              @relation("InvoiceCreatedBy")
  userOrganizationRoles UserOrganizationRole[]

  @@index([email])
  @@index([organizationId])
  @@map("user")
}

// [CHANGE 7] New junction model — replaces the single Role enum
// on User. Each row grants a user a role within one org.
// A SUPER_ADMIN can still be checked via User.role globally.
model UserOrganizationRole {
  id   String @id @default(cuid())
  role Role   @default(USER)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, organizationId]) // One role per user per org
  @@index([organizationId])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  scope                 String?
  password              String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Jwks {
  id         String    @id @default(cuid())
  publicKey  String
  privateKey String
  createdAt  DateTime
  expiresAt  DateTime?

  @@map("jwks")
}

// ============================================================
// Customers
// ============================================================

model Customer {
  id    String  @id @default(cuid())
  name  String
  phone String?
  email String?

  address  String?
  taxId    String? // Customer's VAT number
  notes    String?
  isActive Boolean @default(true)

  // [CHANGE 14] Soft delete — aligned with Item/Supplier pattern
  deletedAt DateTime?

  // [CHANGE 1] Was Int — BigInt prevents overflow on high-value accounts
  creditLimit BigInt @default(0)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices  Invoice[]
  contracts Contract[]

  @@index([organizationId])
  @@index([email])
  @@index([deletedAt])
  // [CHANGE 12] Composite — "active customers for org X" is a common lookup
  @@index([organizationId, isActive])
}

// ============================================================
// Suppliers
// ============================================================

model Supplier {
  id          String    @id @default(cuid())
  name        String
  phone       String?
  email       String?
  address     String?
  contactName String?
  website     String?
  taxId       String?
  notes       String?
  isActive    Boolean   @default(true)
  deletedAt   DateTime? // Soft delete

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  supplierItems  SupplierItem[]
  purchaseOrders PurchaseOrder[]

  @@index([organizationId])
  @@index([deletedAt])
}

// Supplier-specific SKU / price mapping for an Item you stock.
model SupplierItem {
  id          String    @id @default(cuid())
  supplierSku String? // Supplier's part number
  name        String? // Supplier's name for the item
  // [CHANGE 1] Was Int
  basePrice   BigInt
  notes       String?
  isActive    Boolean   @default(true)
  // [CHANGE 14] Added soft delete to match other entity models
  deletedAt   DateTime?

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  // [CHANGE 16] Was ItemId (capital I) — camelCase fix
  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([supplierId, supplierSku])
  @@index([itemId])
  @@index([organizationId])
}

// ============================================================
// Categories
// ============================================================

model Category {
  id    String  @id @default(cuid())
  name  String
  color String?

  // [CHANGE 14] Added soft delete for consistency
  isActive  Boolean   @default(true)
  deletedAt DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items Item[]

  @@unique([name, organizationId])
  @@index([organizationId])
}

// ============================================================
// Items (unified catalog — products AND services)
// ============================================================

model Item {
  id          String    @id @default(cuid())
  type        ItemType  @default(PRODUCT)
  sku         String
  name        String
  description String?
  image       String?
  isActive    Boolean   @default(true)
  deletedAt   DateTime? // Soft delete — never hard-delete referenced items

  // [CHANGE 1] Was Int — BigInt for monetary safety
  purchasePrice BigInt @default(0)
  salesPrice    BigInt @default(0)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  // [CHANGE 4] Was a dangling Int? with no @relation — now a real FK
  taxRateId String?
  taxRate   TaxRate? @relation(fields: [taxRateId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockEntries   Stock[]
  supplierItems  SupplierItem[]
  invoiceLines   InvoiceLine[]
  purchaseLines  PurchaseLine[]
  stockMovements StockMovement[]

  @@unique([sku, organizationId])
  @@index([organizationId])
  @@index([type])
  @@index([deletedAt])
  // [CHANGE 12] Composite — common catalog lookup
  @@index([organizationId, type, isActive])
}

// ============================================================
// Warehouses
// ============================================================

model Warehouse {
  id        String    @id @default(cuid())
  name      String
  address   String?
  isActive  Boolean   @default(true)
  // [CHANGE 14] Added soft delete for consistency
  deletedAt DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stock             Stock[]
  invoices          Invoice[]
  outgoingMovements StockMovement[] @relation("FromStockMovements")
  incomingMovements StockMovement[] @relation("ToStockMovements")

  @@unique([name, organizationId])
  @@index([organizationId])
}

// Per-item, per-warehouse quantity snapshot
model Stock {
  id       String  @id @default(cuid())
  // [CHANGE 19] NOTE: Enforce quantity >= 0 via application layer or
  // raw SQL migration: ALTER TABLE "Stock" ADD CONSTRAINT
  // "stock_quantity_non_negative" CHECK (quantity >= 0);
  quantity Int     @default(0)
  location String? // Bin / shelf reference

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([itemId, warehouseId])
  @@index([organizationId])
}

// ============================================================
// Stock Movements
// [CHANGE 5] New model — was completely missing.
// Every change to Stock.quantity must be backed by a movement
// row. This is the ERP audit trail for inventory: why did the
// quantity change, when, by whom, and linked to which document.
// ============================================================

model StockMovement {
  id       String            @id @default(cuid())
  type     StockMovementType
  // Positive = stock added, negative = stock removed
  quantity Int
  notes    String?

  // Document references (all optional — depends on movement type)
  invoiceLineId String?
  invoiceLine   InvoiceLine? @relation(fields: [invoiceLineId], references: [id])

  purchaseLineId String?
  purchaseLine   PurchaseLine? @relation(fields: [purchaseLineId], references: [id])

  // For TRANSFER movements — source and destination
  fromWarehouseId String?
  fromWarehouse   Warehouse? @relation("FromStockMovements", fields: [fromWarehouseId], references: [id])

  toWarehouseId String?
  toWarehouse   Warehouse? @relation("ToStockMovements", fields: [toWarehouseId], references: [id])

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([itemId])
  @@index([invoiceLineId])
  @@index([purchaseLineId])
  // [CHANGE 12] Composite — audit trail queries are always org + date range
  @@index([organizationId, createdAt])
  @@index([organizationId, type])
  @@index([toWarehouseId])
  @@index([fromWarehouseId])
}

// ============================================================
// Invoices
// ============================================================

model Invoice {
  id String @id @default(cuid())

  type   InvoiceType   @default(INVOICE)
  status InvoiceStatus @default(DRAFT)

  date    DateTime  @default(now())
  // [CHANGE 18] dueDate is still nullable in schema to allow DRAFT state,
  // but application MUST populate it on transition to SENT.
  dueDate DateTime?

  parentInvoiceId String?
  parentInvoice   Invoice?  @relation("CreditNotes", fields: [parentInvoiceId], references: [id])
  creditNotes     Invoice[] @relation("CreditNotes")

  description String?

  // [CHANGE 8] Typed enum
  currency CurrencyCode @default(BHD)

  notes     String?
  termsText String?

  // [CHANGE 1] All totals → BigInt
  subtotal      BigInt @default(0)
  discountTotal BigInt @default(0)
  taxTotal      BigInt @default(0)
  total         BigInt @default(0)

  // [CHANGE 11] Explicit walk-in flag instead of inferring from null customerId
  isWalkIn   Boolean   @default(false)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  userId    String
  createdBy User   @relation("InvoiceCreatedBy", fields: [userId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines             InvoiceLine[]
  payments          Payment[]
  invoiceLineGroups InvoiceLineGroup[]

  @@index([organizationId])
  @@index([customerId])
  @@index([status])
  @@index([type])
  @@index([date])
  @@index([dueDate])
  // [CHANGE 12] Composite indexes — core ERP dashboard queries
  @@index([organizationId, status])
  @@index([organizationId, date])
  @@index([organizationId, type, status])
  @@index([customerId, status])
}

model InvoiceLine {
  id          String  @id @default(cuid())
  description String?

  // [CHANGE 9] Was Int — Decimal supports fractional quantities
  // (e.g. 2.5 kg, 0.5 hours of service billing)
  quantity Decimal @default(1)

  // [CHANGE 1] Prices → BigInt
  purchasePrice BigInt @default(0)
  unitPrice     BigInt @default(0)
  discountAmt   BigInt @default(0)
  taxAmt        BigInt @default(0)
  total         BigInt @default(0)

  itemId String?
  item   Item?   @relation(fields: [itemId], references: [id])

  // [CHANGE 2/3] Now a FK to TaxRate — replaces the raw Int taxRate field.
  // Snapshot of the rate name/% at time of sale is preserved in taxRateSnapshot.
  taxRateId       String?
  taxRate         TaxRate? @relation(fields: [taxRateId], references: [id])
  // Snapshot fields — preserve the rate even if TaxRate row changes later
  taxRateSnapshot Decimal? // e.g. 0.10 for 10%
  taxRateName     String? // e.g. "Standard VAT 10%"

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // [CHANGE 5] Back-reference for StockMovement audit trail
  stockMovements     StockMovement[]
  invoiceLineGroup   InvoiceLineGroup? @relation(fields: [invoiceLineGroupId], references: [id])
  invoiceLineGroupId String?

  @@index([invoiceId])
  @@index([itemId])
}

model InvoiceLineGroup {
  id        String   @id @default(cuid())
  title     String
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ADD: The toggle for the frontend / PDF generator
  showAsSingleLine Boolean @default(true)

  // ADD: Group-level snapshot totals (matching your BigInt pattern)
  subtotal BigInt @default(0)
  taxTotal BigInt @default(0)
  total    BigInt @default(0)

  lines InvoiceLine[]

  @@index([invoiceId])
}

model Payment {
  id        String        @id @default(cuid())
  date      DateTime      @default(now())
  method    PaymentMethod @default(CASH)
  // [CHANGE 1] Was Int
  amount    BigInt
  reference String?
  notes     String?

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  // [CHANGE 10] Direct org FK — eliminates join-through-Invoice for
  // every AR aging report, cash flow dashboard, and audit query.
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId])
  @@index([organizationId])
  // [CHANGE 12] Composite — cash flow queries always filter by org + date
  @@index([organizationId, date])
  @@index([organizationId, method])
}

// ============================================================
// Purchase Orders
// ============================================================

model PurchaseOrder {
  id String @id @default(cuid())

  status       PurchaseStatus @default(DRAFT)
  date         DateTime       @default(now())
  expectedDate DateTime?
  notes        String?

  // [CHANGE 8] Typed enum
  currency CurrencyCode @default(BHD)

  // [CHANGE 1] Totals → BigInt
  subtotal BigInt @default(0)
  taxTotal BigInt @default(0)
  total    BigInt @default(0)

  isReceived Boolean   @default(false)
  receivedAt DateTime?

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines    PurchaseLine[]
  payments PurchasePayment[]

  @@index([supplierId])
  @@index([organizationId])
  @@index([status])
  // [CHANGE 12] Composite — procurement dashboards always org + status/date
  @@index([organizationId, status])
  @@index([organizationId, date])
  @@index([organizationId, supplierId])
}

model PurchaseLine {
  id       String @id @default(cuid())
  quantity Int
  // [CHANGE 1] Was Int
  unitCost BigInt
  taxAmt   BigInt @default(0)
  total    BigInt

  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  receivedQty Int @default(0)

  // [CHANGE 5] Back-reference for StockMovement audit trail
  stockMovements StockMovement[]

  @@index([purchaseOrderId])
  @@index([itemId])
}

model PurchasePayment {
  id        String        @id @default(cuid())
  // [CHANGE 1] Was Int
  amount    BigInt
  method    PaymentMethod @default(TRANSFER)
  date      DateTime      @default(now())
  reference String?
  notes     String?

  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([purchaseOrderId])
}

// ============================================================
// Contracts (CRM — customer agreements, renewals)
// ============================================================

model Contract {
  id          String  @id @default(cuid())
  title       String
  description String?
  isActive    Boolean @default(true)

  // [CHANGE 1] Was Int?
  contractValue BigInt?

  // [CHANGE 8] Typed enum
  currency CurrencyCode @default(BHD)

  startDate        DateTime
  endDate          DateTime
  renewalDate      DateTime?
  renewalAlertDays Int       @default(30)

  // [CHANGE 14] Soft delete added for consistency
  deletedAt DateTime?

  version Int @default(1)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([isActive])
  @@index([endDate])
  @@index([customerId])
  @@index([organizationId, endDate])
  @@index([organizationId, isActive])
  @@index([isActive, endDate]) // "all active contracts expiring soon"
  @@index([organizationId, renewalDate])
  @@index([customerId, isActive])
}
