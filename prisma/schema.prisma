// =============================================================================
// ENTERPRISE ERP SCHEMA  — Prisma 7.x
//
// Key design principles applied across this schema:
//   1. All monetary values stored as Decimal (never Int/Float) with explicit
//      precision/scale annotations where the DB supports it.
//   2. Every table has: id, organizationId, createdAt, updatedAt, deletedAt
//      (soft-delete pattern) — no hard deletes for auditable entities.
//   3. Enums are exhaustive and forward-compatible — new values are additive.
//   4. All FK relations carry explicit onDelete/onUpdate semantics.
//   5. Composite indexes cover the query patterns documented in comments.
//   6. Audit columns (createdById / updatedById) on every mutable entity.
//   7. Optimistic locking via `version Int` on high-contention tables.
//   8. Separate Address model — eliminates 6 copies of the same address fields.
//   9. Multi-currency: exchange rates stored per-document, not assumed static.
//  10. GL (General Ledger) foundation: JournalEntry / JournalLine for double-
//      entry bookkeeping — every financial event posts a balanced entry.
//  11. Attachment model — file references scoped to any entity via polymorphic
//      entityType + entityId pattern (avoids nullable FK explosion).
//  12. AuditLog — immutable event log for compliance / SOC-2 readiness.
//  13. Tag / tagging system for ad-hoc categorisation without schema changes.
//  14. Feature flags per org via OrganizationSetting key-value store.
//  15. Notification model for in-app alert delivery.
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins", "nativeDistinct"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "hrms", "crm"]
}

// =============================================================================
// ENUMS
// =============================================================================

/// ISO 4217 currency codes. Keep in sync with the CURRENCIES constant in
/// lib/currencies.ts.  Adding a new code here is a DB migration + code change.
enum CurrencyCode {
  USD
  BHD
  EUR
  GBP
  JPY
  AED
  SAR
  KWD
  QAR
  OMR

  @@schema("public")
}

/// Platform-wide role. Fine-grained permissions live in Permission / RolePermission.
/// SUPER_ADMIN bypasses all org-level guards.
enum PlatformRole {
  SUPER_ADMIN
  USER

  @@schema("public")
}

/// Org-scoped role assigned via UserOrganizationRole.
/// Permissions are resolved via RolePermission — do not hard-code capability
/// checks against this enum in application code.
enum OrgRole {
  OWNER // Implicit all-permissions; cannot be removed
  ADMIN
  MANAGER
  ACCOUNTANT
  SALES
  WAREHOUSE
  VIEWER

  @@schema("public")
}

/// Whether a catalogue item is a physical product or an intangible service.
enum ItemType {
  PRODUCT
  SERVICE
  BUNDLE // Kit / assembly — composed of other items via BundleLine

  @@schema("public")
}

/// Document types issued to customers.
enum InvoiceType {
  QUOTE
  INVOICE
  CREDIT_NOTE
  PROFORMA // Proforma invoice — not a legal tax document
  DELIVERY_NOTE // Packing slip — no financials

  @@schema("public")
}

/// Lifecycle of a customer-facing document.
enum InvoiceStatus {
  DRAFT
  PENDING_APPROVAL // Awaiting internal sign-off before issue
  APPROVED // Approved, not yet sent
  SENT
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
  DISPUTED // Customer raised a dispute
  DELETED

  @@schema("public")
}

/// Accounts Receivable payment status — denormalised for fast AR aging queries.
enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
  REFUNDED

  @@schema("public")
}

/// Payment methods.
enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  CHEQUE
  ONLINE // Payment gateway (Stripe, Tap, etc.)
  CREDIT // Applied customer credit note
  OTHER

  @@schema("public")
}

/// Contract lifecycle.
enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED

  @@schema("public")
}

/// Purchase order lifecycle.
enum PurchaseStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ORDERED // PO sent to supplier
  PARTIAL_RECEIVED
  RECEIVED
  INVOICED // Supplier invoice received and matched
  CANCELLED
  CLOSED // Fully settled, archived

  @@schema("public")
}

/// Every reason a stock quantity can change. Each StockMovement must carry one.
enum StockMovementType {
  PURCHASE_INBOUND // PO line received
  SALE_OUTBOUND // Invoice confirmed
  RETURN_INBOUND // Customer return / credit note
  RETURN_OUTBOUND // Supplier return
  ADJUSTMENT_UP // Manual positive correction
  ADJUSTMENT_DOWN // Manual write-off / shrinkage
  TRANSFER_OUT // Inter-warehouse transfer — debit side
  TRANSFER_IN // Inter-warehouse transfer — credit side
  OPENING_BALANCE // Initial stock count on go-live
  DAMAGE // Damaged goods write-off
  ASSEMBLY_CONSUME // Raw material consumed in bundle assembly
  ASSEMBLY_PRODUCE // Finished bundle added to stock

  @@schema("public")
}

/// Double-entry bookkeeping — normal balance side of an account.
enum AccountNormalBalance {
  DEBIT
  CREDIT

  @@schema("public")
}

/// Standard chart-of-accounts classification.
enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
  CONTRA_ASSET
  CONTRA_REVENUE

  @@schema("public")
}

/// Journal entry status — posted entries are immutable.
enum JournalStatus {
  DRAFT
  POSTED // Balanced, immutable
  REVERSED // A reversing entry has been created
  VOID // Voided before posting

  @@schema("public")
}

/// Approval workflow status.
enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED

  @@schema("public")
}

/// Notification delivery status.
enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
  DISMISSED

  @@schema("public")
}

// =============================================================================
// DOCUMENT SEQUENCE
// One row per (org, prefix). Lock with SELECT FOR UPDATE inside $transaction.
// PostgreSQL advisory locks or explicit row locks prevent duplicate serials
// under concurrent load — SQLite cannot guarantee this at scale.
// =============================================================================

model DocumentSequence {
  id      String @id @default(cuid())
  prefix  String // "INV" | "QTE" | "CN" | "PO" | "PFI" | "DN"
  nextVal Int    @default(1)

  // Fiscal year — allows per-year numbering (e.g. "INV-2025-00001").
  // null = continuous numbering across years.
  fiscalYear Int?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, prefix, fiscalYear])
  @@index([organizationId])
  @@schema("public")
}

// =============================================================================
// ADDRESS  (shared across Customer, Supplier, Organization, Warehouse)
// Eliminating repeated address columns across 4+ models reduces update anomalies
// and allows customers / suppliers to have multiple addresses (billing vs site).
// =============================================================================

model Address {
  id String @id @default(cuid())

  label       String? // "Head Office", "Billing", "Site 1"
  line1       String
  line2       String?
  city        String?
  state       String?
  postalCode  String?
  countryCode String  @default("BH") // ISO 3166-1 alpha-2

  isDefault Boolean @default(false)
  isPrimary Boolean @default(false) // Used as the primary billing address

  // Polymorphic owner
  entityType String // "Customer" | "Supplier" | "Organization" | "Warehouse"
  entityId   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([entityId])
  @@schema("public")
}

// =============================================================================
// ORGANIZATION  (multi-tenancy root)
// =============================================================================

model Organization {
  id   String @id @default(cuid())
  name String
  slug String @unique

  logo    String?
  phone   String?
  email   String?
  website String?

  // Tax / commercial registration
  taxId         String?
  crNumber      String? // Commercial registration number
  vatRegistered Boolean @default(false)

  // Defaults — all overridable per document
  currency         CurrencyCode @default(BHD)
  paymentTermsDays Int          @default(30)
  defaultTermsText String?
  stampImage       String?
  invoiceFooter    String? // Printed footer on all documents (bank details, etc.)

  // Fiscal year configuration
  fiscalYearStartMonth Int @default(1) // 1 = January, 4 = April, etc.

  // Soft delete / lifecycle
  isActive  Boolean   @default(true)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users                 User[]
  userOrganizationRoles UserOrganizationRole[]
  documentSequences     DocumentSequence[]
  settings              OrganizationSetting[]
  customers             Customer[]
  suppliers             Supplier[]
  items                 Item[]
  itemCategories        ItemCategory[]
  taxRates              TaxRate[]
  warehouses            Warehouse[]
  stocks                Stock[]
  stockMovements        StockMovement[]
  invoices              Invoice[]
  invoiceLines          InvoiceLine[]
  payments              Payment[]
  purchaseOrders        PurchaseOrder[]
  purchasePayments      PurchasePayment[]
  contracts             Contract[]
  supplierItems         SupplierItem[]
  expenseCategories     ExpenseCategory[]
  expenses              Expense[]
  incomes               Income[]
  chartOfAccounts       LedgerAccount[]
  journalEntries        JournalEntry[]
  exchangeRates         ExchangeRate[]
  approvalWorkflows     ApprovalWorkflow[]
  approvalRequests      ApprovalRequest[]
  tags                  Tag[]
  notifications         Notification[]
  auditLogs             AuditLog[]
  bundles               BundleLine[]
  priceListHeaders      PriceList[]
  creditNoteAllocations CreditNoteAllocation[]
  departments           Department[]
  categoryFamilies      CategoryFamily[]
  categoryClasses       CategoryClass[]
  categoryCommodities   CategoryCommodity[]
  roles                 Role[]

  // HRMS relations
  employees           Employee[]
  employeeDocuments   EmployeeDocument[]
  jobPositions        JobPosition[]
  leaveTypes          LeaveType[]
  leaveRequests       LeaveRequest[]
  attendanceRecords   AttendanceRecord[]
  payrollRuns         PayrollRun[]
  payrollItems        PayrollItem[]
  salaryComponents    SalaryComponent[]
  performanceReviews  PerformanceReview[]
  candidates          Candidate[]
  jobPostings         JobPosting[]
  trainings           Training[]
  trainingEnrollments TrainingEnrollment[]
  shifts              Shift[]
  employeeShifts      EmployeeShift[]

  // CRM relations
  leads          Lead[]
  opportunities  Opportunity[]
  pipelines      Pipeline[]
  activities     Activity[]
  campaigns      Campaign[]
  contacts       Contact[]
  emailTemplates EmailTemplate[]
  crmTasks       Task[]

  @@index([slug])
  @@index([deletedAt])
  @@schema("public")
}

/// Per-org feature flags and configuration.
/// Avoids schema migrations for runtime-configurable options.
model OrganizationSetting {
  id    String @id @default(cuid())
  key   String // e.g. "feature.approvals", "invoice.autoSendEmail"
  value String // JSON-serialised value

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  updatedAt DateTime @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId])
  @@schema("public")
}

// =============================================================================
// AUTH  (Better Auth — table/field names must not be renamed)
// =============================================================================

model User {
  id            String  @id @default(cuid())
  name          String
  email         String  @unique
  emailVerified Boolean @default(false)
  image         String?
  firstName     String?
  lastName      String?
  locale        String  @default("en")
  timezone      String  @default("Asia/Bahrain") // ← NEW: per-user timezone for date display
  isActive      Boolean @default(true)

  // Admin plugin — used by better-auth for RBAC on admin endpoints
  role String @default("admin")

  platformRole PlatformRole @default(USER) // ← renamed from `role` for clarity

  // Primary org (for single-org users set at onboarding)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  // 2FA / security (Better Auth extension fields)
  twoFactorEnabled Boolean @default(false)

  // Soft delete — deactivated users retain audit trail
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts              Account[]
  sessions              Session[]
  userOrganizationRoles UserOrganizationRole[]

  // Audit back-references
  createdInvoices       Invoice[]          @relation("InvoiceCreatedBy")
  updatedInvoices       Invoice[]          @relation("InvoiceUpdatedBy")
  createdPurchaseOrders PurchaseOrder[]    @relation("POCreatedBy")
  updatedPurchaseOrders PurchaseOrder[]    @relation("POUpdatedBy")
  stockMovements        StockMovement[]
  createdExpenses       Expense[]          @relation("ExpenseCreatedBy")
  createdIncomes        Income[]           @relation("IncomeCreatedBy")
  approvalRequests      ApprovalRequest[]
  approvalDecisions     ApprovalDecision[]
  notifications         Notification[]
  auditLogs             AuditLog[]
  createdJournalEntries JournalEntry[]     @relation("JournalCreatedBy")
  createdContracts      Contract[]         @relation("ContractCreatedBy")
  updatedContracts      Contract[]         @relation("ContractUpdatedBy")

  // HRMS
  employee              Employee?
  approvedLeaveRequests LeaveRequest[]
  processedPayrollRuns  PayrollRun[]
  reviewedPerformances  PerformanceReview[]
  uploadedDocuments     EmployeeDocument[]

  // CRM
  assignedLeads         Lead[]
  assignedOpportunities Opportunity[]
  assignedActivities    Activity[]
  assignedCrmTasks      Task[]

  @@index([email])
  @@index([organizationId])
  @@index([deletedAt])
  @@map("user")
  @@schema("public")
}

/// Grants a user a specific role within one org.
/// Permissions are resolved through RolePermission — roles are labels,
/// not hard-coded capability sets.
model UserOrganizationRole {
  id   String  @id @default(cuid())
  role OrgRole @default(VIEWER) // ⚠️ kept for migration — will be removed after data migration

  roleId     String?
  customRole Role?   @relation(fields: [roleId], references: [id])

  // Custom display name for this user in the org context
  jobTitle String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Department / cost centre for P&L segmentation
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
  @@index([role])
  @@index([roleId])
  @@schema("public")
}

// =============================================================================
// RBAC — Role-based access control
// =============================================================================

/// Named permission e.g. "invoice:create", "stock:adjust", "report:financial".
model Permission {
  id          String  @id @default(cuid())
  code        String  @unique // machine-readable e.g. "invoice:delete"
  label       String // Human label e.g. "Delete Invoices"
  description String?
  module      String // Grouping: "Invoicing", "Inventory", "Purchasing"

  rolePermissions RolePermission[]

  @@schema("public")
}

/// Dynamic role — system roles (OWNER, ADMIN…) are seeded globally;
/// custom roles are created per-org by the OWNER.
model Role {
  id          String  @id @default(cuid())
  name        String
  description String?
  icon        String?
  color       String?

  /// true for system roles (OWNER, ADMIN, MANAGER, etc.)
  isSystem  Boolean @default(false)
  /// Machine key for system roles: "OWNER", "ADMIN", "MANAGER", etc.
  /// Null for custom roles.
  systemKey String? @unique

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  userOrganizationRoles UserOrganizationRole[]
  rolePermissions       RolePermission[]
  approvalSteps         ApprovalStep[]

  @@index([organizationId])
  @@schema("public")
}

/// Maps a Role to a set of permissions.
model RolePermission {
  id   String  @id @default(cuid())
  role OrgRole // ⚠️ kept for migration — will be removed after data migration

  roleId     String?
  customRole Role?   @relation(fields: [roleId], references: [id])

  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
  @@index([roleId])
  @@schema("public")
}

// =============================================================================
// DEPARTMENTS  (cost centre segmentation)
// =============================================================================

model Department {
  id   String  @id @default(cuid())
  name String
  code String? // Short code for GL posting

  parentId String?
  parent   Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children Department[] @relation("DepartmentHierarchy")

  isActive  Boolean   @default(true)
  deletedAt DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userOrganizationRoles UserOrganizationRole[]
  expenses              Expense[]
  invoiceLines          InvoiceLine[]
  journalLines          JournalLine[]
  invoices              Invoice[]
  purchaseOrders        PurchaseOrder[]

  // HRMS
  employees Employee[]

  @@unique([name, organizationId])
  @@index([organizationId])
  @@index([parentId])
  @@schema("public")
}

// =============================================================================
// BETTER AUTH standard models (unchanged names — library requirement)
// =============================================================================

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("session")
  @@schema("public")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  scope                 String?
  password              String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("account")
  @@schema("public")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
  @@schema("public")
}

model Jwks {
  id         String    @id @default(cuid())
  publicKey  String
  privateKey String
  createdAt  DateTime
  expiresAt  DateTime?

  @@map("jwks")
  @@schema("public")
}

// =============================================================================
// TAX RATES
// =============================================================================

model TaxRate {
  id   String @id @default(cuid())
  name String

  // Stored as percentage e.g. 10.00 = 10%.  Application divides by 100.
  rate      Decimal @db.Decimal(7, 4) // supports e.g. 5.5000%
  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  // GL account for tax liability posting
  taxLiabilityAccountId String?
  taxLiabilityAccount   LedgerAccount? @relation(fields: [taxLiabilityAccountId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items         Item[]
  invoiceLines  InvoiceLine[]
  purchaseLines PurchaseLine[]

  @@unique([name, organizationId])
  @@index([organizationId])
  @@index([isActive, organizationId])
  @@schema("public")
}

// =============================================================================
// EXCHANGE RATES
// Stored per org per date — enables multi-currency historical reporting.
// Rate = how many units of toCurrency per 1 unit of fromCurrency.
// =============================================================================

model ExchangeRate {
  id            String       @id @default(cuid())
  fromCurrency  CurrencyCode
  toCurrency    CurrencyCode
  rate          Decimal      @db.Decimal(18, 8)
  effectiveDate DateTime

  source String? // "ECB" | "manual" | "provider_name"

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())

  @@unique([organizationId, fromCurrency, toCurrency, effectiveDate])
  @@index([organizationId, effectiveDate])
  @@index([fromCurrency, toCurrency, effectiveDate])
  @@schema("public")
}

// =============================================================================
// CHART OF ACCOUNTS  (double-entry GL)
// =============================================================================

/// A single account in the chart of accounts.
/// Accounts form a tree: root accounts have no parent.
model LedgerAccount {
  id            String               @id @default(cuid())
  code          String // e.g. "1010", "4000" — unique per org
  name          String
  description   String?
  type          AccountType
  normalBalance AccountNormalBalance

  // Tree structure — allows account grouping for P&L / balance sheet
  parentId String?
  parent   LedgerAccount?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children LedgerAccount[] @relation("AccountHierarchy")

  isActive           Boolean @default(true)
  isSystemAccount    Boolean @default(false) // System accounts cannot be deleted
  allowDirectPosting Boolean @default(true) // Header accounts = false

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  journalLines      JournalLine[]
  taxRates          TaxRate[]
  items             Item[]            @relation("ItemRevenueAccount")
  itemCOGS          Item[]            @relation("ItemCOGSAccount")
  itemInventory     Item[]            @relation("ItemInventoryAccount")
  expenseCategories ExpenseCategory[]

  @@unique([code, organizationId])
  @@index([organizationId])
  @@index([type, organizationId])
  @@index([parentId])
  @@schema("public")
}

// =============================================================================
// JOURNAL ENTRIES  (immutable double-entry records)
// Every financial event (invoice, payment, PO receipt, expense) creates a
// JournalEntry with balanced JournalLine rows.  Posted entries are never
// modified — reversals are new entries.
// =============================================================================

model JournalEntry {
  id          String        @id @default(cuid())
  entryNumber String // Human-readable: "JE-000123"
  status      JournalStatus @default(DRAFT)
  date        DateTime

  description  String?
  reference    String? // Source document reference (invoice serial, PO serial)
  currency     CurrencyCode
  exchangeRate Decimal      @default(1) @db.Decimal(18, 8)

  // Source document back-references (all optional)
  invoiceId       String?
  purchaseOrderId String?
  expenseId       String?
  paymentId       String?

  // Reversal link
  reversedById String?       @unique // JE that reversed this one
  reversedBy   JournalEntry? @relation("JournalReversal", fields: [reversedById], references: [id])
  reversalOf   JournalEntry? @relation("JournalReversal")

  createdById String
  createdBy   User   @relation("JournalCreatedBy", fields: [createdById], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  postedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  lines JournalLine[]

  @@unique([entryNumber, organizationId])
  @@index([organizationId])
  @@index([date, organizationId])
  @@index([invoiceId])
  @@index([purchaseOrderId])
  @@index([status, organizationId])
  @@schema("public")
}

/// One debit or credit line within a journal entry.
model JournalLine {
  id String @id @default(cuid())

  // Exactly one of debit/credit is non-zero; the other is zero.
  // Constraint enforced at application layer: SUM(debit) == SUM(credit) per entry.
  debit  Decimal @default(0) @db.Decimal(20, 6)
  credit Decimal @default(0) @db.Decimal(20, 6)

  description String?

  accountId String
  account   LedgerAccount @relation(fields: [accountId], references: [id])

  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  // Cost centre tagging for department-level P&L
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  organizationId String

  createdAt DateTime @default(now())

  @@index([journalEntryId])
  @@index([accountId])
  @@index([organizationId, accountId])
  @@index([departmentId])
  @@schema("public")
}

// =============================================================================
// APPROVAL WORKFLOWS
// =============================================================================

/// An approval workflow template tied to a document type and threshold.
model ApprovalWorkflow {
  id              String   @id @default(cuid())
  name            String
  entityType      String // "Invoice" | "PurchaseOrder" | "Expense"
  amountThreshold Decimal? @db.Decimal(20, 6) // Trigger if total > threshold

  isActive Boolean @default(true)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  steps    ApprovalStep[]
  requests ApprovalRequest[]

  @@unique([entityType, organizationId])
  @@index([organizationId])
  @@schema("public")
}

model ApprovalStep {
  id        String  @id @default(cuid())
  stepOrder Int
  role      OrgRole // ⚠️ kept for migration — will be removed after data migration
  required  Boolean @default(true)

  roleId     String?
  customRole Role?   @relation(fields: [roleId], references: [id])

  workflowId String
  workflow   ApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, stepOrder])
  @@index([workflowId])
  @@index([roleId])
  @@schema("public")
}

/// An approval request raised for a specific document.
model ApprovalRequest {
  id          String         @id @default(cuid())
  entityType  String
  entityId    String
  status      ApprovalStatus @default(PENDING)
  currentStep Int            @default(1)

  workflowId String
  workflow   ApprovalWorkflow @relation(fields: [workflowId], references: [id])

  requestedById String
  requestedBy   User   @relation(fields: [requestedById], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  decisions ApprovalDecision[]

  @@index([entityType, entityId])
  @@index([organizationId, status])
  @@index([workflowId])
  @@schema("public")
}

model ApprovalDecision {
  id        String         @id @default(cuid())
  stepOrder Int
  status    ApprovalStatus
  notes     String?

  requestId String
  request   ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  decidedById String
  decidedBy   User   @relation(fields: [decidedById], references: [id])

  createdAt DateTime @default(now())

  @@index([requestId])
  @@schema("public")
}

// =============================================================================
// TAGS  (ad-hoc labelling without schema changes)
// =============================================================================

model Tag {
  id    String  @id @default(cuid())
  name  String
  color String? // Hex

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  taggings Tagging[]

  @@unique([name, organizationId])
  @@index([organizationId])
  @@schema("public")
}

/// Polymorphic join: a tag applied to any entity.
model Tagging {
  id         String @id @default(cuid())
  entityType String // "Customer" | "Item" | "Invoice" | ...
  entityId   String

  tagId String
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([entityType, entityId, tagId])
  @@index([entityType, entityId])
  @@index([tagId])
  @@schema("public")
}

// =============================================================================
// NOTIFICATIONS
// =============================================================================

model Notification {
  id     String             @id @default(cuid())
  title  String
  body   String?
  status NotificationStatus @default(UNREAD)
  type   String // "contract_renewal" | "low_stock" | "overdue_invoice" | ...

  // Deep-link target
  entityType String?
  entityId   String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime  @default(now())
  readAt    DateTime?

  @@index([userId, status])
  @@index([organizationId])
  @@index([entityType, entityId])
  @@schema("public")
}

// =============================================================================
// AUDIT LOG  (immutable compliance trail)
// Every create/update/delete on sensitive models writes a row here.
// Application is responsible for calling this — no DB triggers in Prisma.
// =============================================================================

model AuditLog {
  id         String  @id @default(cuid())
  entityType String // "Invoice" | "Payment" | "StockMovement" | ...
  entityId   String
  action     String // "CREATE" | "UPDATE" | "DELETE" | "STATUS_CHANGE"
  diff       Json? // JSON patch of changed fields (before/after)
  ipAddress  String?
  userAgent  String?

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([organizationId, createdAt])
  @@index([userId])
  @@schema("public")
}

// =============================================================================
// FILES  (deduplicated physical file records)
// SHA-256 hash ensures identical content is stored only once.
// =============================================================================

model File {
  id           String   @id @default(cuid())
  filename     String   // UUID-based storage filename
  originalName String   // User's original filename
  hash         String   @unique // SHA-256 hex digest
  storagePath  String   @unique // e.g. /uploads/2025/07/abc123.jpg
  mime         String   // Resolved MIME type (from file-type, not user-supplied)
  extension    String   // Canonical extension (e.g. jpg, pdf, png)
  size         Int      // File size in bytes (after optimization)
  width        Int?     // Image width in pixels (null for non-images)
  height       Int?     // Image height in pixels (null for non-images)
  createdAt    DateTime @default(now())
  attachments  Attachment[]

  @@schema("public")
}

// =============================================================================
// ATTACHMENTS  (polymorphic file references)
// Links a File to any ERP entity (Invoice, Customer, Employee, etc.)
// Reference-counted: File is only deleted when all Attachments are removed.
// =============================================================================

model Attachment {
  id             String   @id @default(cuid())
  fileId         String
  file           File     @relation(fields: [fileId], references: [id])
  entityType     String   // e.g. "Invoice", "Customer", "Employee"
  entityId       String   // The ID of the related entity
  field          String?  // Optional semantic role (e.g. "signature", "profilePhoto")
  label          String?  // Display label (e.g. "Supplier Invoice", "Delivery Note")
  uploadedById   String?
  organizationId String
  createdAt      DateTime @default(now())

  @@index([entityType, entityId])
  @@index([organizationId])
  @@index([fileId])
  @@schema("public")
}

// =============================================================================
// ITEM CATEGORIES
// =============================================================================

model ItemCategory {
  id    String  @id @default(cuid())
  name  String
  color String?
  icon  String? // Icon identifier for UI

  parentId String?
  parent   ItemCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ItemCategory[] @relation("CategoryHierarchy")

  isActive  Boolean   @default(true)
  deletedAt DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items Item[]

  @@unique([name, organizationId])
  @@index([organizationId])
  @@index([deletedAt])
  @@index([parentId])
  @@map("Category")
  @@schema("public")
}

// =============================================================================
// 3-LAYER UNIVERSAL CATEGORIZATION  (Family → Class → Commodity)
// Strict hierarchical categories for classifying catalogue items at three
// levels of granularity. Each level has a code unique within its parent + org.
// =============================================================================

/// Layer 1 — "What is it?"  e.g. RAW, FIN, MRO, WIP, SVC
model CategoryFamily {
  id          String  @id @default(cuid())
  name        String
  code        String // Short code, unique per org (e.g. "RAW", "FIN")
  description String?
  color       String? // Hex colour for UI badges
  icon        String? // Icon identifier for UI

  isActive  Boolean   @default(true)
  deletedAt DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classes CategoryClass[]
  items   Item[]

  @@unique([code, organizationId])
  @@index([organizationId])
  @@index([deletedAt])
  @@schema("public")
}

/// Layer 2 — "What does it do?"  e.g. ELEC, METL, FURN
model CategoryClass {
  id          String  @id @default(cuid())
  name        String
  code        String // Short code, unique per family + org (e.g. "ELEC")
  description String?
  color       String?
  icon        String?

  isActive  Boolean   @default(true)
  deletedAt DateTime?

  familyId String
  family   CategoryFamily @relation(fields: [familyId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  commodities CategoryCommodity[]
  items       Item[]

  @@unique([code, familyId, organizationId])
  @@index([organizationId])
  @@index([familyId])
  @@index([deletedAt])
  @@schema("public")
}

/// Layer 3 — "Which specific one?"  e.g. CABLE, SWITCH, CAMERA
model CategoryCommodity {
  id          String  @id @default(cuid())
  name        String
  code        String // Short code, unique per class + org (e.g. "CABLE")
  description String?
  color       String?
  icon        String?

  isActive  Boolean   @default(true)
  deletedAt DateTime?

  classId String
  class   CategoryClass @relation(fields: [classId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items Item[]

  @@unique([code, classId, organizationId])
  @@index([organizationId])
  @@index([classId])
  @@index([deletedAt])
  @@schema("public")
}

// =============================================================================
// PRICE LISTS
// Supports tiered / customer-specific pricing without modifying Item.salesPrice.
// =============================================================================

model PriceList {
  id          String       @id @default(cuid())
  name        String
  currency    CurrencyCode @default(BHD)
  isDefault   Boolean      @default(false)
  validFrom   DateTime?
  validTo     DateTime?
  description String?

  isActive  Boolean   @default(true)
  deletedAt DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines     PriceListLine[]
  customers Customer[]

  @@unique([name, organizationId])
  @@index([organizationId])
  @@schema("public")
}

model PriceListLine {
  id        String  @id @default(cuid())
  unitPrice Decimal @db.Decimal(20, 6)

  // Optional minimum quantity for tiered pricing
  minQty Decimal @default(1)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  priceListId String
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)

  @@unique([priceListId, itemId, minQty])
  @@index([priceListId])
  @@index([itemId])
  @@schema("public")
}

// =============================================================================
// CUSTOMERS
// =============================================================================

model Customer {
  id   String  @id @default(cuid())
  name String
  code String? // Short customer code e.g. "CUST-0042"

  phone    String?
  email    String?
  taxId    String?
  crNumber String? // Commercial registration

  notes     String?
  isActive  Boolean   @default(true)
  deletedAt DateTime?

  creditLimit     Decimal @default(0) @db.Decimal(20, 6)
  creditTermsDays Int     @default(30)

  // Assigned price list — overrides Item.salesPrice for this customer
  priceListId String?
  priceList   PriceList? @relation(fields: [priceListId], references: [id])

  // Currency override — if customer transacts in a non-default currency
  currencyCode CurrencyCode?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Audit
  createdById String?
  updatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices  Invoice[]
  contracts Contract[]
  incomes   Income[]

  // CRM
  leadConversions  Lead[]
  crmOpportunities Opportunity[]
  crmContacts      Contact[]

  @@index([organizationId])
  @@index([email])
  @@index([deletedAt])
  @@index([organizationId, isActive])
  @@index([code, organizationId])
  @@schema("public")
}

// =============================================================================
// SUPPLIERS
// =============================================================================

model Supplier {
  id          String    @id @default(cuid())
  name        String
  code        String? // "SUP-0001"
  phone       String?
  email       String?
  contactName String?
  website     String?
  taxId       String?
  crNumber    String?
  notes       String?
  isActive    Boolean   @default(true)
  isSystem    Boolean   @default(false)
  deletedAt   DateTime?

  // Default payment terms for this supplier
  paymentTermsDays Int @default(30)

  // Default currency this supplier invoices in
  currencyCode CurrencyCode?

  // GL account for AP posting
  payablesAccountId String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  supplierItems  SupplierItem[]
  purchaseOrders PurchaseOrder[]

  @@index([organizationId])
  @@index([deletedAt])
  @@index([organizationId, isActive])
  @@index([code, organizationId])
  @@schema("public")
}

/// Supplier-specific pricing for a catalogue item.
model SupplierItem {
  id           String       @id @default(cuid())
  supplierSku  String?
  supplierName String?
  basePrice    Decimal      @db.Decimal(20, 6)
  currency     CurrencyCode @default(BHD)
  leadTimeDays Int?
  minOrderQty  Decimal      @default(1)
  notes        String?
  isActive     Boolean      @default(true)
  deletedAt    DateTime?

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([supplierId, supplierSku])
  @@unique([supplierId, itemId])
  @@index([itemId])
  @@index([organizationId])
  @@index([supplierId])
  @@schema("public")
}

// =============================================================================
// ITEMS  (unified catalogue)
// =============================================================================

model Item {
  id          String   @id @default(cuid())
  type        ItemType @default(PRODUCT)
  sku         String
  barcode     String? // EAN / UPC for scanning
  name        String
  description String?
  image       String?
  unit        String   @default("pcs")

  isActive      Boolean   @default(true)
  isSaleable    Boolean   @default(true)
  isPurchasable Boolean   @default(true) // Can be on a PO
  deletedAt     DateTime?

  // Pricing
  purchasePrice Decimal @default(0) @db.Decimal(20, 6)
  salesPrice    Decimal @default(0) @db.Decimal(20, 6)

  // Landed cost / average cost for COGS calculation
  averageCost Decimal @default(0) @db.Decimal(20, 6)

  // Stock settings
  minStock     Int @default(0)
  reorderPoint Int @default(0) // Trigger PO suggestion at this level
  reorderQty   Int @default(0) // Suggested order quantity

  // Dimensions / weight (for logistics)
  weightKg Decimal? @db.Decimal(10, 4)
  widthCm  Decimal? @db.Decimal(10, 2)
  heightCm Decimal? @db.Decimal(10, 2)
  depthCm  Decimal? @db.Decimal(10, 2)

  // GL accounts — override org defaults per item
  revenueAccountId   String?
  revenueAccount     LedgerAccount? @relation("ItemRevenueAccount", fields: [revenueAccountId], references: [id])
  cogsAccountId      String?
  cogsAccount        LedgerAccount? @relation("ItemCOGSAccount", fields: [cogsAccountId], references: [id])
  inventoryAccountId String?
  inventoryAccount   LedgerAccount? @relation("ItemInventoryAccount", fields: [inventoryAccountId], references: [id])

  categoryId String?
  category   ItemCategory? @relation(fields: [categoryId], references: [id])

  // 3-Layer Universal Categorization (nullable for backward compatibility)
  familyId String?
  family   CategoryFamily? @relation(fields: [familyId], references: [id])

  classId String?
  class   CategoryClass? @relation(fields: [classId], references: [id])

  commodityId String?
  commodity   CategoryCommodity? @relation(fields: [commodityId], references: [id])

  taxRateId String?
  taxRate   TaxRate? @relation(fields: [taxRateId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Audit
  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stock            Stock[]
  supplierItems    SupplierItem[]
  invoiceLines     InvoiceLine[]
  purchaseLines    PurchaseLine[]
  stockMovements   StockMovement[]
  expenses         Expense[]
  bundleLines      BundleLine[]    @relation("BundleParent")
  bundleComponents BundleLine[]    @relation("BundleComponent")
  priceListLines   PriceListLine[]

  @@unique([sku, organizationId])
  @@index([organizationId])
  @@index([type])
  @@index([deletedAt])
  @@index([organizationId, type, isActive])
  @@index([organizationId, isSaleable, isActive])
  @@index([barcode, organizationId])
  @@schema("public")
}

/// Bundle (kit) composition — defines which components make up a BUNDLE item.
model BundleLine {
  id       String  @id @default(cuid())
  quantity Decimal @db.Decimal(10, 4)

  // The BUNDLE parent item
  bundleItemId String
  bundleItem   Item   @relation("BundleParent", fields: [bundleItemId], references: [id])

  // The component item
  componentItemId String
  componentItem   Item   @relation("BundleComponent", fields: [componentItemId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([bundleItemId, componentItemId])
  @@index([bundleItemId])
  @@index([componentItemId])
  @@schema("public")
}

// =============================================================================
// WAREHOUSES
// =============================================================================

model Warehouse {
  id        String    @id @default(cuid())
  name      String
  code      String? // Short code e.g. "WH-01"
  isActive  Boolean   @default(true)
  isDefault Boolean   @default(false)
  deletedAt DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stock             Stock[]
  invoices          Invoice[]
  purchaseOrders    PurchaseOrder[]
  outgoingMovements StockMovement[] @relation("FromWarehouseMovements")
  incomingMovements StockMovement[] @relation("ToWarehouseMovements")

  @@unique([name, organizationId])
  @@index([organizationId])
  @@index([deletedAt])
  @@schema("public")
}

/// Per-item, per-warehouse stock level.
/// Quantity ONLY changes via StockMovement inside a $transaction.
/// optimistic locking via `version` prevents lost updates under concurrency.
model Stock {
  id       String  @id @default(cuid())
  quantity Decimal @default(0) @db.Decimal(14, 4) // Decimal to support fractional units
  location String?
  version  Int     @default(0) // Optimistic lock — increment on every update

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([itemId, warehouseId])
  @@index([organizationId])
  @@index([warehouseId])
  @@index([organizationId, itemId])
  @@schema("public")
}

/// Immutable audit trail for every stock quantity change.
model StockMovement {
  id       String            @id @default(cuid())
  type     StockMovementType
  quantity Decimal           @db.Decimal(14, 4) // Positive = in, Negative = out

  // Unit cost at time of movement — needed for average cost / COGS calculations
  unitCost Decimal? @db.Decimal(20, 6)

  notes String?

  // Source document back-references
  invoiceLineId  String?
  invoiceLine    InvoiceLine?  @relation(fields: [invoiceLineId], references: [id])
  purchaseLineId String?
  purchaseLine   PurchaseLine? @relation(fields: [purchaseLineId], references: [id])

  // Transfer warehouses
  fromWarehouseId String?
  fromWarehouse   Warehouse? @relation("FromWarehouseMovements", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String?
  toWarehouse     Warehouse? @relation("ToWarehouseMovements", fields: [toWarehouseId], references: [id])

  // Paired transfer movement (TRANSFER_OUT ↔ TRANSFER_IN)
  pairedMovementId String?

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Immutable — intentionally no updatedAt
  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([itemId])
  @@index([invoiceLineId])
  @@index([purchaseLineId])
  @@index([organizationId, createdAt])
  @@index([organizationId, type])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([organizationId, itemId, createdAt])
  @@schema("public")
}

// =============================================================================
// INVOICES
// =============================================================================

model Invoice {
  id     String @id @default(cuid())
  serial String // e.g. "INV-2025-00042"

  type          InvoiceType   @default(INVOICE)
  status        InvoiceStatus @default(DRAFT)
  paymentStatus PaymentStatus @default(PENDING)

  date    DateTime  @default(now())
  dueDate DateTime?

  // Credit note — references reversed invoice
  parentInvoiceId String?
  parentInvoice   Invoice?  @relation("CreditNotes", fields: [parentInvoiceId], references: [id])
  creditNotes     Invoice[] @relation("CreditNotes")

  // Quote conversion
  convertedFromId String?
  convertedFrom   Invoice?  @relation("QuoteConversions", fields: [convertedFromId], references: [id])
  conversions     Invoice[] @relation("QuoteConversions")

  description   String?
  notes         String?
  termsText     String?
  internalNotes String? // ← NEW: not printed on document — staff only

  currency     CurrencyCode @default(BHD)
  exchangeRate Decimal      @default(1) @db.Decimal(18, 8) // Rate vs org base currency at invoice date

  // Totals
  subtotal      Decimal @default(0) @db.Decimal(20, 6)
  discountTotal Decimal @default(0) @db.Decimal(20, 6)
  taxTotal      Decimal @default(0) @db.Decimal(20, 6)
  total         Decimal @default(0) @db.Decimal(20, 6)
  amountPaid    Decimal @default(0) @db.Decimal(20, 6)
  amountDue     Decimal @default(0) @db.Decimal(20, 6)

  // Cost of goods for gross profit calculation
  costTotal Decimal @default(0) @db.Decimal(20, 6)

  isWalkIn   Boolean   @default(false)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  // Department for P&L segmentation
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  // Approval
  approvalStatus ApprovalStatus?

  // Audit
  createdById String
  createdBy   User    @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   User?   @relation("InvoiceUpdatedBy", fields: [updatedById], references: [id])

  // Optimistic lock
  version Int @default(0)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  sentAt      DateTime? // When status moved to SENT
  cancelledAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lines                 InvoiceLine[]
  payments              Payment[]
  creditNoteAllocations CreditNoteAllocation[]
  incomes               Income[]

  @@unique([serial, organizationId])
  @@index([organizationId])
  @@index([customerId])
  @@index([status])
  @@index([type])
  @@index([date])
  @@index([dueDate])
  @@index([organizationId, status])
  @@index([organizationId, date])
  @@index([organizationId, type, status])
  @@index([customerId, status])
  @@index([organizationId, paymentStatus])
  @@index([organizationId, dueDate])
  @@index([deletedAt])
  @@index([departmentId])
  @@schema("public")
}

model InvoiceLine {
  id          String  @id @default(cuid())
  description String?
  quantity    Decimal @default(1) @db.Decimal(14, 4)
  sortOrder   Int     @default(0)

  // Pricing
  purchasePrice Decimal @default(0) @db.Decimal(20, 6)
  unitPrice     Decimal @default(0) @db.Decimal(20, 6)
  discountPct   Decimal @default(0) @db.Decimal(7, 4) // ← NEW: percentage discount for display
  discountAmt   Decimal @default(0) @db.Decimal(20, 6)
  taxAmt        Decimal @default(0) @db.Decimal(20, 6)
  total         Decimal @default(0) @db.Decimal(20, 6)

  // Item
  itemId String?
  item   Item?   @relation(fields: [itemId], references: [id])

  // Tax snapshot
  taxRateId       String?
  taxRate         TaxRate? @relation(fields: [taxRateId], references: [id])
  taxRateSnapshot Decimal? @db.Decimal(7, 4)
  taxRateName     String?

  // Cost centre
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockMovements StockMovement[]

  @@index([invoiceId])
  @@index([itemId])
  @@index([invoiceId, sortOrder])
  @@index([departmentId])
  @@schema("public")
}

/// Tracks allocation of credit notes against specific invoices.
/// Prevents double-applying a credit note and gives a clear offset audit trail.
model CreditNoteAllocation {
  id String @id @default(cuid())

  // The credit note being applied
  creditNoteId String
  creditNote   Invoice @relation(fields: [creditNoteId], references: [id])

  // The invoice being offset
  invoiceId String

  amount    Decimal  @db.Decimal(20, 6)
  appliedAt DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([creditNoteId, invoiceId])
  @@index([creditNoteId])
  @@index([invoiceId])
  @@index([organizationId])
  @@schema("public")
}

/// Customer payment against an invoice.
model Payment {
  id        String        @id @default(cuid())
  date      DateTime      @default(now())
  method    PaymentMethod @default(CASH)
  amount    Decimal       @db.Decimal(20, 6)
  reference String?
  notes     String?

  // Gateway transaction ID (for online payments)
  gatewayTxnId  String?
  gatewayStatus String?

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // GL journal for this payment
  journalEntryId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId])
  @@index([organizationId])
  @@index([organizationId, date])
  @@index([organizationId, method])
  @@index([gatewayTxnId])
  @@schema("public")
}

// =============================================================================
// PURCHASE ORDERS
// =============================================================================

model PurchaseOrder {
  id     String @id @default(cuid())
  serial String

  status       PurchaseStatus @default(DRAFT)
  date         DateTime       @default(now())
  expectedDate DateTime?
  receivedAt   DateTime?

  notes         String?
  internalNotes String?
  currency      CurrencyCode @default(BHD)
  exchangeRate  Decimal      @default(1) @db.Decimal(18, 8)

  // Totals
  subtotal   Decimal @default(0) @db.Decimal(20, 6)
  taxTotal   Decimal @default(0) @db.Decimal(20, 6)
  total      Decimal @default(0) @db.Decimal(20, 6)
  amountPaid Decimal @default(0) @db.Decimal(20, 6)
  amountOwed Decimal @default(0) @db.Decimal(20, 6)

  // Approval
  approvalStatus ApprovalStatus?

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  // Department / cost centre
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  // Audit
  createdById String
  createdBy   User    @relation("POCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   User?   @relation("POUpdatedBy", fields: [updatedById], references: [id])

  version Int @default(0)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  cancelledAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lines    PurchaseLine[]
  payments PurchasePayment[]

  @@unique([serial, organizationId])
  @@index([supplierId])
  @@index([organizationId])
  @@index([status])
  @@index([warehouseId])
  @@index([organizationId, status])
  @@index([organizationId, date])
  @@index([organizationId, supplierId])
  @@index([createdById])
  @@index([deletedAt])
  @@index([departmentId])
  @@schema("public")
}

model PurchaseLine {
  id          String  @id @default(cuid())
  quantity    Decimal @db.Decimal(14, 4)
  receivedQty Decimal @default(0) @db.Decimal(14, 4)
  unitCost    Decimal @db.Decimal(20, 6)
  taxAmt      Decimal @default(0) @db.Decimal(20, 6)
  total       Decimal @db.Decimal(20, 6)

  // Tax snapshot (mirrors InvoiceLine pattern for consistent history)
  taxRateId       String?
  taxRate         TaxRate? @relation(fields: [taxRateId], references: [id])
  taxRateSnapshot Decimal? @db.Decimal(7, 4)
  taxRateName     String?

  description String? // Supplier-side description if different from item name

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  stockMovements StockMovement[]

  @@index([purchaseOrderId])
  @@index([itemId])
  @@schema("public")
}

/// Payment made to a supplier against a purchase order.
model PurchasePayment {
  id        String        @id @default(cuid())
  amount    Decimal       @db.Decimal(20, 6)
  method    PaymentMethod @default(BANK_TRANSFER)
  date      DateTime      @default(now())
  reference String?
  notes     String?

  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  journalEntryId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([purchaseOrderId])
  @@index([organizationId])
  @@index([organizationId, date])
  @@schema("public")
}

// =============================================================================
// CONTRACTS
// =============================================================================

model Contract {
  id            String         @id @default(cuid())
  serial        String // e.g. "CTR-2026-00001"
  title         String
  description   String?
  status        ContractStatus @default(DRAFT)
  contractValue Decimal?       @db.Decimal(20, 6)
  currency      CurrencyCode   @default(BHD)

  startDate        DateTime
  endDate          DateTime
  renewalDate      DateTime?
  renewalAlertDays Int       @default(30)
  version          Int       @default(1)

  notes     String?
  deletedAt DateTime?

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  // Responsible sales person
  ownerId String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdById String?
  createdBy   User?   @relation("ContractCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   User?   @relation("ContractUpdatedBy", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serial, organizationId])
  @@index([organizationId])
  @@index([status])
  @@index([endDate])
  @@index([customerId])
  @@index([deletedAt])
  @@index([organizationId, endDate])
  @@index([organizationId, status])
  @@index([status, endDate])
  @@index([organizationId, renewalDate])
  @@index([customerId, status])
  @@schema("public")
}

// =============================================================================
// EXPENSES
// =============================================================================

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String
  isActive  Boolean   @default(true)
  deletedAt DateTime?

  // GL account for posting this expense category
  accountId String?
  account   LedgerAccount? @relation(fields: [accountId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenses Expense[]

  @@unique([name, organizationId])
  @@index([organizationId])
  @@schema("public")
}

model Expense {
  id          String        @id @default(cuid())
  description String
  amount      Decimal       @db.Decimal(20, 6)
  date        DateTime      @default(now())
  reference   String?
  notes       String?
  method      PaymentMethod @default(CASH)
  isRecurring Boolean       @default(false) // Flag for recurring expense patterns

  categoryId String?
  category   ExpenseCategory? @relation(fields: [categoryId], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  itemId String?
  item   Item?   @relation(fields: [itemId], references: [id])

  journalEntryId String?

  createdById String
  createdBy   User   @relation("ExpenseCreatedBy", fields: [createdById], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([categoryId])
  @@index([organizationId, date])
  @@index([organizationId, categoryId])
  @@index([deletedAt])
  @@index([departmentId])
  @@index([journalEntryId])
  @@schema("public")
}

model Income {
  id          String   @id @default(cuid())
  description String
  amount      Decimal  @db.Decimal(20, 6)
  date        DateTime @default(now())
  reference   String?
  notes       String?

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  createdById String
  createdBy   User   @relation("IncomeCreatedBy", fields: [createdById], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([organizationId])
  @@index([invoiceId])
  @@index([organizationId, date])
  @@index([deletedAt])
  @@schema("public")
}

// =============================================================================
// DEPARTMENT back-references that couldn't be declared inline above
// (Prisma requires models to be declared before relations in some cases)
// =============================================================================
// Note: Department.invoiceLines, .expenses already declared via relation fields
// on InvoiceLine and Expense. No additional model needed here.
// =============================================================================
// HRMS — Human Resource Management System  (hrms schema)
// All models integrate with ERP core via Organization (org-scoped) and User.
// =============================================================================

// ── HRMS Enums ───────────────────────────────────────────────────────────────

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  FREELANCE

  @@schema("hrms")
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
  RESIGNED
  SUSPENDED

  @@schema("hrms")
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED

  @@schema("hrms")
}

enum PayrollStatus {
  DRAFT
  PROCESSING
  COMPLETED
  CANCELLED

  @@schema("hrms")
}

enum PerformanceRating {
  EXCEEDS_EXPECTATIONS
  MEETS_EXPECTATIONS
  NEEDS_IMPROVEMENT
  BELOW_EXPECTATIONS

  @@schema("hrms")
}

enum CandidateStatus {
  NEW
  SCREENING
  INTERVIEW
  OFFERED
  HIRED
  REJECTED
  WITHDRAWN

  @@schema("hrms")
}

enum TrainingStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED

  @@schema("hrms")
}

// ── HRMS Models ──────────────────────────────────────────────────────────────

/// Core employee record linked to a User account for authentication.
model Employee {
  id           String @id @default(cuid())
  employeeCode String // "EMP-00001"

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  hireDate       DateTime
  employmentType EmploymentType @default(FULL_TIME)
  status         EmployeeStatus @default(ACTIVE)

  phone            String?
  emergencyContact String?
  emergencyPhone   String?
  bankAccount      String?
  bankName         String?

  jobPositionId String?
  jobPosition   JobPosition? @relation(fields: [jobPositionId], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  reportsToId   String?
  reportsTo     Employee?  @relation("EmployeeSupervision", fields: [reportsToId], references: [id])
  directReports Employee[] @relation("EmployeeSupervision")

  salaryAmount   Decimal?      @db.Decimal(20, 6)
  salaryCurrency CurrencyCode?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  leaveRequests       LeaveRequest[]
  attendanceRecords   AttendanceRecord[]
  payrollItems        PayrollItem[]
  salaryComponents    SalaryComponent[]
  performanceReviews  PerformanceReview[]
  employeeDocuments   EmployeeDocument[]
  trainingEnrollments TrainingEnrollment[]
  employeeShifts      EmployeeShift[]

  @@unique([employeeCode, organizationId])
  @@index([organizationId])
  @@index([userId])
  @@index([departmentId])
  @@index([status])
  @@index([reportsToId])
  @@schema("hrms")
}

/// Job positions / roles within the organization.
model JobPosition {
  id           String  @id @default(cuid())
  name         String
  code         String?
  description  String?
  requirements String?

  isActive  Boolean   @default(true)
  deletedAt DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  parentId String?
  parent   JobPosition?  @relation("JobPositionHierarchy", fields: [parentId], references: [id])
  children JobPosition[] @relation("JobPositionHierarchy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]

  @@unique([name, organizationId])
  @@index([organizationId])
  @@index([parentId])
  @@schema("hrms")
}

/// Types of leave (Annual, Sick, Emergency, etc.).
model LeaveType {
  id          String  @id @default(cuid())
  name        String
  code        String // "ANNUAL" | "SICK" | "EMERGENCY" | "MATERNITY" | "PERSONAL"
  description String?
  daysPerYear Int     @default(30)
  isPaid      Boolean @default(true)
  isActive    Boolean @default(true)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leaveRequests LeaveRequest[]

  @@unique([code, organizationId])
  @@index([organizationId])
  @@schema("hrms")
}

/// Leave request submitted by an employee with approval workflow.
model LeaveRequest {
  id           String      @id @default(cuid())
  startDate    DateTime
  endDate      DateTime
  durationDays Int
  reason       String?
  status       LeaveStatus @default(PENDING)
  notes        String?

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])

  approvedById String?
  approvedBy   User?     @relation(fields: [approvedById], references: [id])
  approvedAt   DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([organizationId])
  @@index([status])
  @@index([startDate, endDate])
  @@schema("hrms")
}

/// Daily attendance check-in/out records.
model AttendanceRecord {
  id         String    @id @default(cuid())
  date       DateTime  @default(now())
  checkIn    DateTime
  checkOut   DateTime?
  breakStart DateTime?
  breakEnd   DateTime?
  totalHours Decimal?  @db.Decimal(6, 2)
  notes      String?

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([organizationId])
  @@index([organizationId, date])
  @@schema("hrms")
}

/// Monthly payroll run batch.
model PayrollRun {
  id              String        @id @default(cuid())
  name            String // "Payroll June 2026"
  periodStart     DateTime
  periodEnd       DateTime
  status          PayrollStatus @default(DRAFT)
  totalSalaries   Decimal       @default(0) @db.Decimal(20, 6)
  totalDeductions Decimal       @default(0) @db.Decimal(20, 6)
  totalNetPay     Decimal       @default(0) @db.Decimal(20, 6)
  processedAt     DateTime?
  notes           String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  processedById String?
  processedBy   User?   @relation(fields: [processedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items PayrollItem[]

  @@unique([name, organizationId])
  @@index([organizationId])
  @@index([status])
  @@schema("hrms")
}

/// Per-employee payroll line within a payroll run.
model PayrollItem {
  id          String    @id @default(cuid())
  baseSalary  Decimal   @db.Decimal(20, 6)
  allowances  Decimal   @default(0) @db.Decimal(20, 6)
  deductions  Decimal   @default(0) @db.Decimal(20, 6)
  bonus       Decimal   @default(0) @db.Decimal(20, 6)
  overtime    Decimal   @default(0) @db.Decimal(20, 6)
  tax         Decimal   @default(0) @db.Decimal(20, 6)
  netPay      Decimal   @db.Decimal(20, 6)
  bankAccount String?
  bankName    String?
  paymentDate DateTime?
  notes       String?

  payrollRunId String
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([payrollRunId, employeeId])
  @@index([payrollRunId])
  @@index([employeeId])
  @@index([organizationId])
  @@schema("hrms")
}

/// Employee salary components (basic, housing, transport, etc.).
model SalaryComponent {
  id          String  @id @default(cuid())
  name        String // "Basic", "Housing", "Transport", "Food"
  type        String // "ALLOWANCE" | "DEDUCTION"
  amount      Decimal @db.Decimal(20, 6)
  isRecurring Boolean @default(true)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([organizationId])
  @@schema("hrms")
}

/// Employee performance review / appraisal.
model PerformanceReview {
  id           String            @id @default(cuid())
  reviewPeriod String // "Q1 2026", "Annual 2026"
  reviewDate   DateTime          @default(now())
  rating       PerformanceRating
  comments     String?
  goals        String?
  strengths    String?
  weaknesses   String?
  status       String            @default("DRAFT") // DRAFT | SUBMITTED | ACKNOWLEDGED

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  reviewerId String
  reviewer   User   @relation(fields: [reviewerId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([organizationId])
  @@index([reviewerId])
  @@schema("hrms")
}

/// Employee documents (contract, ID, certificates, etc.).
model EmployeeDocument {
  id         String    @id @default(cuid())
  name       String
  type       String // "CONTRACT" | "ID" | "CERTIFICATE" | "EDUCATION" | "OTHER"
  fileUrl    String
  mimeType   String?
  sizeBytes  Int?
  expiryDate DateTime?
  notes      String?

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  uploadedById String?
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([organizationId])
  @@index([type])
  @@schema("hrms")
}

/// Job posting for recruitment.
model JobPosting {
  id             String         @id @default(cuid())
  title          String
  description    String?
  requirements   String?
  location       String?
  employmentType EmploymentType @default(FULL_TIME)
  salaryMin      Decimal?       @db.Decimal(20, 6)
  salaryMax      Decimal?       @db.Decimal(20, 6)
  currency       CurrencyCode   @default(BHD)
  isActive       Boolean        @default(true)
  closingDate    DateTime?
  publishedAt    DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  candidates Candidate[]

  @@index([organizationId])
  @@index([isActive])
  @@schema("hrms")
}

/// Job candidate / applicant.
model Candidate {
  id            String          @id @default(cuid())
  firstName     String
  lastName      String
  email         String
  phone         String?
  resumeUrl     String?
  coverLetter   String?
  status        CandidateStatus @default(NEW)
  source        String? // "LinkedIn" | "Referral" | "Job Portal"
  notes         String?
  interviewDate DateTime?
  offerAmount   Decimal?        @db.Decimal(20, 6)

  jobPostingId String?
  jobPosting   JobPosting? @relation(fields: [jobPostingId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobPostingId])
  @@index([organizationId])
  @@index([email])
  @@index([status])
  @@schema("hrms")
}

/// Training / course programs.
model Training {
  id            String         @id @default(cuid())
  name          String
  description   String?
  provider      String?
  durationHours Int?
  cost          Decimal?       @db.Decimal(20, 6)
  currency      CurrencyCode   @default(BHD)
  startDate     DateTime?
  endDate       DateTime?
  isMandatory   Boolean        @default(false)
  status        TrainingStatus @default(PLANNED)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments TrainingEnrollment[]

  @@index([organizationId])
  @@schema("hrms")
}

/// Employee enrollment in a training program.
model TrainingEnrollment {
  id          String         @id @default(cuid())
  status      TrainingStatus @default(PLANNED)
  score       Decimal?       @db.Decimal(5, 2)
  completedAt DateTime?
  notes       String?

  trainingId String
  training   Training @relation(fields: [trainingId], references: [id])

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([trainingId, employeeId])
  @@index([trainingId])
  @@index([employeeId])
  @@index([organizationId])
  @@schema("hrms")
}

/// Work shift definitions.
model Shift {
  id        String  @id @default(cuid())
  name      String // "Morning", "Evening", "Night"
  startTime String // "08:00"
  endTime   String // "16:00"
  color     String? // Hex for calendar display
  isActive  Boolean @default(true)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employeeShifts EmployeeShift[]

  @@unique([name, organizationId])
  @@index([organizationId])
  @@schema("hrms")
}

/// Employee shift assignments.
model EmployeeShift {
  id        String   @id @default(cuid())
  date      DateTime
  startTime String? // Override shift default
  endTime   String? // Override shift default
  notes     String?

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  shiftId String
  shift   Shift  @relation(fields: [shiftId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, shiftId, date])
  @@index([employeeId])
  @@index([shiftId])
  @@index([organizationId])
  @@schema("hrms")
}

// =============================================================================
// CRM — Customer Relationship Management  (crm schema)
// All models integrate with ERP core via Organization, User, and Customer.
// =============================================================================

// ── CRM Enums ────────────────────────────────────────────────────────────────

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  DISQUALIFIED
  CONVERTED

  @@schema("crm")
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
  ABANDONED

  @@schema("crm")
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED

  @@schema("crm")
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT

  @@schema("crm")
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED

  @@schema("crm")
}

// ── CRM Models ───────────────────────────────────────────────────────────────

/// Marketing lead / prospect.
model Lead {
  id          String     @id @default(cuid())
  firstName   String
  lastName    String
  email       String?
  phone       String?
  company     String?
  jobTitle    String?
  source      String? // "Website" | "Referral" | "LinkedIn" | "Event"
  status      LeadStatus @default(NEW)
  score       Int        @default(0)
  notes       String?
  convertedAt DateTime?

  // Converted to ERP Customer
  convertedToCustomerId String?
  convertedToCustomer   Customer? @relation(fields: [convertedToCustomerId], references: [id])

  assignedToId String?
  assignedTo   User?   @relation(fields: [assignedToId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  opportunities Opportunity[]
  activities    Activity[]
  campaigns     CampaignMember[]
  tasks         Task[]

  @@index([organizationId])
  @@index([assignedToId])
  @@index([status])
  @@index([email])
  @@index([organizationId, status])
  @@schema("crm")
}

/// Lead source tracking.
model LeadSource {
  id       String  @id @default(cuid())
  name     String // "Website", "Referral", "Cold Call", "Event"
  code     String  @unique
  isActive Boolean @default(true)

  @@schema("crm")
}

/// Sales opportunity with pipeline tracking.
model Opportunity {
  id              String            @id @default(cuid())
  name            String
  description     String?
  amount          Decimal?          @db.Decimal(20, 6)
  currency        CurrencyCode      @default(BHD)
  probability     Int               @default(50) // 0-100
  expectedCloseAt DateTime?
  status          OpportunityStatus @default(OPEN)
  closedAt        DateTime?
  closedReason    String?
  notes           String?

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  pipelineId String?
  pipeline   Pipeline? @relation(fields: [pipelineId], references: [id])

  pipelineStageId String?
  pipelineStage   PipelineStage? @relation(fields: [pipelineStageId], references: [id])

  assignedToId String?
  assignedTo   User?   @relation(fields: [assignedToId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  activities Activity[]
  tasks      Task[]

  @@index([organizationId])
  @@index([leadId])
  @@index([customerId])
  @@index([pipelineId])
  @@index([pipelineStageId])
  @@index([assignedToId])
  @@index([status])
  @@schema("crm")
}

/// Sales pipeline definition.
model Pipeline {
  id          String  @id @default(cuid())
  name        String
  description String?

  isActive  Boolean @default(true)
  isDefault Boolean @default(false)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stages        PipelineStage[]
  opportunities Opportunity[]

  @@unique([name, organizationId])
  @@index([organizationId])
  @@schema("crm")
}

/// Stage within a sales pipeline.
model PipelineStage {
  id          String @id @default(cuid())
  name        String // "Prospecting", "Qualification", "Proposal", "Negotiation"
  order       Int
  probability Int    @default(50) // Default probability for this stage

  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  opportunities Opportunity[]

  @@unique([pipelineId, order])
  @@unique([pipelineId, name])
  @@index([pipelineId])
  @@schema("crm")
}

/// CRM activity (call, email, meeting, note).
model Activity {
  id          String   @id @default(cuid())
  type        String // "CALL" | "EMAIL" | "MEETING" | "NOTE" | "DEMO"
  subject     String
  description String?
  date        DateTime @default(now())
  durationMin Int?
  outcome     String?
  notes       String?

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id])

  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  assignedToId String?
  assignedTo   User?   @relation(fields: [assignedToId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([opportunityId])
  @@index([contactId])
  @@index([assignedToId])
  @@index([organizationId])
  @@index([organizationId, date])
  @@schema("crm")
}

/// Activity type configuration.
model ActivityType {
  id       String  @id @default(cuid())
  name     String // "Call", "Email", "Meeting", "Demo"
  icon     String?
  color    String?
  isActive Boolean @default(true)

  @@schema("crm")
}

/// Marketing campaign.
model Campaign {
  id             String         @id @default(cuid())
  name           String
  description    String?
  type           String // "EMAIL" | "SOCIAL" | "EVENT" | "REFERRAL"
  status         CampaignStatus @default(DRAFT)
  budget         Decimal?       @db.Decimal(20, 6)
  currency       CurrencyCode   @default(BHD)
  startDate      DateTime?
  endDate        DateTime?
  targetAudience String?
  notes          String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members CampaignMember[]

  @@index([organizationId])
  @@index([status])
  @@schema("crm")
}

/// Campaign member (lead/contact in a campaign).
model CampaignMember {
  id          String    @id @default(cuid())
  status      String    @default("SENT") // "SENT" | "OPENED" | "CLICKED" | "REPLIED" | "BOUNCED"
  respondedAt DateTime?

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  @@unique([campaignId, leadId])
  @@unique([campaignId, contactId])
  @@index([campaignId])
  @@index([leadId])
  @@index([contactId])
  @@schema("crm")
}

/// CRM contact (person at a company, separate from ERP Customer entity).
model Contact {
  id        String  @id @default(cuid())
  firstName String
  lastName  String
  email     String?
  phone     String?
  jobTitle  String?
  isPrimary Boolean @default(false)
  notes     String?

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities Activity[]
  campaigns  CampaignMember[]
  tasks      Task[]

  @@index([organizationId])
  @@index([customerId])
  @@index([email])
  @@schema("crm")
}

/// Email template for CRM communications.
model EmailTemplate {
  id       String  @id @default(cuid())
  name     String
  subject  String
  body     String
  category String? // "FOLLOW_UP" | "WELCOME" | "PROMOTION" | "GENERAL"
  isActive Boolean @default(true)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, organizationId])
  @@index([organizationId])
  @@schema("crm")
}

/// CRM follow-up task.
model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(PENDING)
  completedAt DateTime?

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id])

  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  assignedToId String?
  assignedTo   User?   @relation(fields: [assignedToId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([opportunityId])
  @@index([contactId])
  @@index([assignedToId])
  @@index([organizationId])
  @@index([status])
  @@schema("crm")
}
