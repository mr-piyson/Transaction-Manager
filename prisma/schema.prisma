// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ENUMS
enum CurrencyCode {
  BHD
  USD
  EUR
}

enum InvoiceStatus {
  DRAFT
  APPROVED
  SENT
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK
  CARD
  CHEQUE
  ONLINE
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

model Organization {
  id      Int     @id @default(autoincrement())
  name    String
  logo    String?
  address String?
  country String?
  website String?
  tax     String?

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String
  firstName    String
  lastName     String?
  role         Role    @default(USER)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tokens Tokens[]

  @@index([email])
  @@index([role])
}

model Tokens {
  id         Int       @id @default(autoincrement())
  type       String?
  value      String?   @unique
  expiresAt  DateTime?
  deviceInfo String?
  ipAddress  String?
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @default(now()) @updatedAt
  userId     String
  user       User?     @relation(fields: [userId], references: [id])

  @@index([expiresAt])
}

model InventoryItem {
  id            Int           @id @default(autoincrement())
  code          String?
  name          String
  description   String?
  purchasePrice Int
  salesPrice    Int
  image         String?
  invoice       Invoice?      @relation(fields: [invoiceId], references: [id])
  invoiceId     Int?
  invoiceItems  InvoiceItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}

model Customer {
  id       Int       @id @default(autoincrement())
  name     String
  phone    String
  address  String
  email    String?
  invoices Invoice[]

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}

model Invoice {
  id          Int            @id @default(autoincrement())
  date        DateTime       @default(now())
  description String?
  customerId  Int?
  tax         Int?
  status      InvoiceStatus? @default(DRAFT)
  currency    CurrencyCode   @default(BHD)

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  // Relations
  payments     Payment[]
  invoiceItems InventoryItem[]
  customer     Customer?       @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([status])
}

model InvoiceItem {
  id              Int            @id @default(autoincrement())
  code            String?        @unique
  description     String?
  purchasePrice   Int
  salesPrice      Int
  itemRef         InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  inventoryItemId Int?
  total           Int

  // Self-referential relations for Bundles/Packages
  parentId Int?
  parent   InvoiceItem?  @relation("BundleToItems", fields: [parentId], references: [id], onDelete: Cascade)
  subItems InvoiceItem[] @relation("BundleToItems")

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}

model Payment {
  id        Int           @id @default(autoincrement())
  date      DateTime      @default(now()) // Maps to draft.date
  method    PaymentMethod @default(CASH)
  amount    Int // Stored in fils
  reference String? // Cheque # or Transaction ID
  notes     String? // Optional note

  // Relations
  invoiceId Int
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}
model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  date      DateTime
  method    String
  amount    Int
  reference String?
  notes     String?
}