// Prisma schema — compatible with both SQLite (dev) and PostgreSQL (prod)
// Switch provider via DATABASE_PROVIDER env var or by editing the datasource block.
// All monetary values are stored as Int in the smallest currency unit (e.g. fils for BHD, cents for USD).

generator client {
  provider = "prisma-client-js"
}

// -------------------------------------------------------
// For SQLite (local dev):
//   provider = "sqlite"
//   url      = "file:./dev.db"
//
// For PostgreSQL (production):
//   provider = "postgresql"
//   url      = env("DATABASE_URL")
// -------------------------------------------------------
datasource db {
  provider = "sqlite"
}

// ====================================================
// Settings
// ====================================================

model Organization {
  id       Int     @id @default(autoincrement())
  name     String
  logo     String?
  address  String?
  website  String?
  tax      String?
  slug     String  @unique
  currency String  @default("BHD")

  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  users          User[]
  contracts      Contract[]
  invoices       Invoice[]
  customers      Customer[]
  inventoryItems InventoryItem[]
}

// ====================================================
// Auth
// ====================================================

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Custom Fields
  firstName String?
  lastName  String?
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  locale    String   @default("en")

  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  accounts      Account[]
  sessions      Session[]
  invoices      Invoice[]

  @@index([email])
  @@index([organizationId])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Jwks {
  id         String    @id
  publicKey  String
  privateKey String
  createdAt  DateTime
  expiresAt  DateTime?

  @@map("jwks")
}



// ====================================================
// Inventory
// ====================================================

model InventoryItem {
  id            Int     @id @default(autoincrement())
  code          String?
  name          String
  description   String?
  /// Stored in smallest currency unit (e.g. fils)
  purchasePrice Int
  /// Stored in smallest currency unit (e.g. fils)
  salesPrice    Int
  filePath      String?
  image      String?

  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  invoiceLines InvoiceLine[]

  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  @@index([organizationId])
  @@index([code])
}

// ====================================================
// Invoices
// ====================================================

enum InvoicePaymentStatus {
  Paid
  Unpaid
  Partial
}

enum PaymentMethod {
  CASH
  TRANSFER
}

model Invoice {
  id            Int                  @id @default(autoincrement())
  date          DateTime?            @default(now())
  description   String?
  paymentStatus InvoicePaymentStatus @default(Unpaid)
  isCompleted   Boolean              @default(false)
  currency      String               @default("BHD")

  /// All totals stored in smallest currency unit (e.g. fils)
  subtotal      Int @default(0)
  discountTotal Int @default(0)
  taxTotal      Int @default(0)
  total         Int @default(0)

  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id])

  userId    String
  createdBy User   @relation(fields: [userId], references: [id])

  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  payments     Payment[]
  invoiceLines InvoiceLine[]

  @@index([customerId])
  @@index([userId])
  @@index([organizationId])
  @@index([isCompleted])
  @@index([paymentStatus])
  @@index([date])
}

model InvoiceLine {
  id            Int     @id @default(autoincrement())
  description   String?
  /// Stored in smallest currency unit (e.g. fils)
  purchasePrice Int
  /// Stored in smallest currency unit (e.g. fils)
  salesPrice    Int
  quantity      Int     @default(1)
  /// Stored in smallest currency unit (e.g. fils)
  total         Int

  inventoryItemId Int?
  itemRef         InventoryItem? @relation(fields: [inventoryItemId], references: [id])

  invoiceId Int?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  @@index([invoiceId])
  @@index([inventoryItemId])
}

model Payment {
  id        Int           @id @default(autoincrement())
  date      DateTime?     @default(now())
  method    PaymentMethod @default(CASH)
  /// Stored in smallest currency unit (e.g. fils)
  amount    Int
  reference String?
  notes     String?

  invoiceId Int
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  @@index([invoiceId])
}

// ====================================================
// Customers
// ====================================================

model Customer {
  id      Int     @id @default(autoincrement())
  name    String
  phone   String
  address String
  email   String?

  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  invoices Invoice[]

  @@index([organizationId])
}

// ====================================================
// Contracts
// ====================================================

model Contract {
  id          String  @id @default(uuid())
  title       String
  description String?
  active      Boolean @default(true)

  /// Stored in smallest currency unit (e.g. fils)
  contractValue Int?
  currency      String @default("BHD")

  startDate   DateTime
  endDate     DateTime
  renewalDate DateTime?

  version Int @default(1)

  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  @@index([organizationId])
  @@index([active])
  @@index([endDate])
}
