// ============================================================
// Prisma Schema — ERP / CRM
// Compatible with SQLite (dev) and PostgreSQL (prod)
// All monetary values stored as Int in smallest currency unit
// (e.g. fils for BHD, cents for USD).
//
// SQLite  → provider = "sqlite",     url = "file:./dev.db"
// Postgres→ provider = "postgresql", url = env("DATABASE_URL")
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ============================================================
// Enums
// ============================================================

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

enum ItemType {
  PRODUCT // Physical goods — tracked in stock
  SERVICE // Intangible — no stock tracking
}

enum InvoiceType {
  INVOICE
  CREDIT_NOTE // Linked to a parent Invoice via parentInvoiceId
  QUOTE // Can be converted to an Invoice
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  CANCELLED
  DELETED
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  CHEQUE
  OTHER
}

enum PurchaseStatus {
  DRAFT
  ORDERED
  PARTIAL_RECEIVED
  RECEIVED
  CANCELLED
}

// ============================================================
// Organization (multi-tenancy root)
// ============================================================

model Organization {
  id      Int     @id @default(autoincrement())
  name    String
  logo    String?
  address String?
  website String?
  taxId   String? // VAT / CR number shown on documents
  slug    String  @unique

  // Default currency for this org (ISO 4217, e.g. "BHD", "USD")
  currency String @default("BHD")

  // Default payment terms in days (e.g. 30 → Net 30)
  paymentTermsDays Int @default(30)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  customers      Customer[]
  suppliers      Supplier[]
  Items          Item[]
  warehouses     Warehouse[]
  stocks         Stock[]
  categories     Category[]
  invoices       Invoice[]
  purchaseOrders PurchaseOrder[]
  taxRates       TaxRate[]
  contracts      Contract[]
  supplierItems  SupplierItem[]
}

// ============================================================
// Auth
// ============================================================

model User {
  id            String  @id
  name          String
  email         String  @unique
  emailVerified Boolean @default(false)
  image         String?

  firstName String?
  lastName  String?
  role      Role    @default(USER)
  isActive  Boolean @default(true)
  locale    String  @default("en")

  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  sessions Session[]
  invoices Invoice[] @relation("InvoiceCreatedBy")

  @@index([email])
  @@index([organizationId])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  scope                 String?
  password              String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Jwks {
  id         String    @id
  publicKey  String
  privateKey String
  createdAt  DateTime
  expiresAt  DateTime?

  @@map("jwks")
}

// ============================================================
// Tax Rates  (reusable — attach to lines or items)
// ============================================================

model TaxRate {
  id        Int     @id @default(autoincrement())
  name      String // e.g. "VAT 10%", "Zero Rated"
  rate      Int // Stored as basis points: 1000 = 10.00%
  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])

  Items        Item[]
  invoiceLines InvoiceLine[]

  @@unique([name, organizationId])
  @@index([organizationId])
}

// ============================================================
// Customers
// ============================================================

model Customer {
  id        Int       @id @default(autoincrement())
  name      String
  phone     String?
  email     String?
  address   String?
  taxId     String? // Customer's VAT number
  notes     String?
  isActive  Boolean   @default(true)
  deletedAt DateTime? // Soft delete

  // Credit limit in smallest currency unit (0 = no limit)
  creditLimit Int @default(0)

  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices  Invoice[]
  contracts Contract[]

  @@index([organizationId])
  @@index([email])
  @@index([deletedAt])
}

// ============================================================
// Suppliers  (fully optional — only needed for purchase flow)
// ============================================================

model Supplier {
  id          Int       @id @default(autoincrement())
  name        String
  phone       String?
  email       String?
  address     String?
  contactName String?
  website     String?
  taxId       String?
  notes       String?
  isActive    Boolean   @default(true)
  deletedAt   DateTime? // Soft delete

  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Supplier-specific catalog (optional — maps their SKU/price to your Item)
  supplierItems  SupplierItem[]
  purchaseOrders PurchaseOrder[]

  @@index([organizationId])
  @@index([deletedAt])
}

// Supplier's own SKU / price for an item you stock.
// Optional layer — only needed when the same Item has
// different supplier codes or prices across suppliers.
model SupplierItem {
  id          Int     @id @default(autoincrement())
  supplierSku String? // Supplier's part number
  name        String? // Supplier's name for the item (may differ from yours)
  basePrice   Int // Cost price in smallest currency unit
  notes       String?
  isActive    Boolean @default(true)

  supplierId Int
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  // Maps to your internal catalog item
  ItemId Int
  Item   Item @relation(fields: [ItemId], references: [id])

  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([supplierId, supplierSku])
  @@index([ItemId])
  @@index([organizationId])
}

// ============================================================
// Categories
// ============================================================

model Category {
  id    Int     @id @default(autoincrement())
  name  String
  color String?

  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Items Item[]

  @@unique([name, organizationId])
  @@index([organizationId])
}

// ============================================================
// Items  (unified catalog — products AND services)
// ============================================================

model Item {
  id          Int       @id @default(autoincrement())
  type        ItemType  @default(PRODUCT)
  sku         String
  name        String
  description String?
  image       String?
  isActive    Boolean   @default(true)
  deletedAt   DateTime? // Soft delete — never hard-delete referenced items

  // Default prices in smallest currency unit
  purchasePrice Int @default(0)
  salesPrice    Int @default(0)

  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id])

  // Default tax rate (can be overridden per invoice line)
  taxRateId Int?
  taxRate   TaxRate? @relation(fields: [taxRateId], references: [id])

  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  stockEntries  Stock[]
  supplierItems SupplierItem[]
  invoiceLines  InvoiceLine[]
  purchaseLines PurchaseLine[]

  @@unique([sku, organizationId])
  @@index([organizationId])
  @@index([type])
  @@index([deletedAt])
}

// ============================================================
// Warehouses
// ============================================================

model Warehouse {
  id       Int     @id @default(autoincrement())
  name     String
  address  String?
  isActive Boolean @default(true)

  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stock    Stock[]
  invoices Invoice[]

  @@unique([name, organizationId])
  @@index([organizationId])
}

// Per-item, per-warehouse quantity
model Stock {
  id       Int     @id @default(autoincrement())
  quantity Int     @default(0)
  location String? // Bin / shelf reference

  ItemId Int
  Item   Item @relation(fields: [ItemId], references: [id])

  warehouseId Int
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One row per item per warehouse
  @@unique([ItemId, warehouseId])
  @@index([organizationId])
}

// ============================================================
// Invoices
// ============================================================

model Invoice {
  id Int @id @default(autoincrement())

  type   InvoiceType   @default(INVOICE)
  status InvoiceStatus @default(DRAFT)

  date    DateTime  @default(now())
  dueDate DateTime? // Populated from paymentTermsDays at creation

  // For credit notes — reference the original invoice
  parentInvoiceId Int?
  parentInvoice   Invoice?  @relation("CreditNotes", fields: [parentInvoiceId], references: [id])
  creditNotes     Invoice[] @relation("CreditNotes")

  description String?
  currency    String  @default("BHD")
  notes       String? // Internal notes
  termsText   String? // Terms shown on the document

  // All totals in smallest currency unit
  subtotal      Int @default(0)
  discountTotal Int @default(0)
  taxTotal      Int @default(0)
  total         Int @default(0)

  // Optional — walk-in / anonymous sales allowed
  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id])

  warehouseId Int?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  userId    String
  createdBy User   @relation("InvoiceCreatedBy", fields: [userId], references: [id])

  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines    InvoiceLine[]
  payments Payment[]

  @@unique([id, organizationId])
  @@index([organizationId])
  @@index([customerId])
  @@index([status])
  @@index([type])
  @@index([date])
  @@index([dueDate])
}

model InvoiceLine {
  id          Int     @id @default(autoincrement())
  description String? // Override item name for this line
  quantity    Int     @default(1)

  // Prices at time of sale — snapshot, not live lookup
  purchasePrice Int @default(0) // Cost (for margin reporting)
  unitPrice     Int // Sale price per unit
  discountAmt   Int @default(0) // Line-level discount in smallest unit
  taxAmt        Int @default(0) // Calculated tax amount
  total         Int // (unitPrice × qty) - discountAmt + taxAmt

  // The item being sold — single FK to Item
  ItemId Int?
  Item   Item? @relation(fields: [ItemId], references: [id])

  // Which tax rate was applied (snapshot reference)
  taxRateId Int?
  taxRate   TaxRate? @relation(fields: [taxRateId], references: [id])

  invoiceId Int
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  // Line grouping (e.g. bundle header + child lines)
  isGroup    Boolean       @default(false)
  parentId   Int?
  parentLine InvoiceLine?  @relation("GroupedLines", fields: [parentId], references: [id], onDelete: Cascade)
  childLines InvoiceLine[] @relation("GroupedLines")

  sortOrder Int @default(0) // Display order in the invoice

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId])
  @@index([ItemId])
  @@index([parentId])
}

model Payment {
  id        Int           @id @default(autoincrement())
  date      DateTime      @default(now())
  method    PaymentMethod @default(CASH)
  amount    Int // In smallest currency unit
  reference String? // Cheque number, transfer ref, etc.
  notes     String?

  invoiceId Int
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId])
}

// ============================================================
// Purchase Orders  (buy side — supplier optional for quick POs)
// ============================================================

model PurchaseOrder {
  id Int @id @default(autoincrement())

  status       PurchaseStatus @default(DRAFT)
  date         DateTime       @default(now())
  expectedDate DateTime? // Expected delivery date
  notes        String?
  currency     String         @default("BHD")

  // Totals in smallest currency unit
  subtotal Int @default(0)
  taxTotal Int @default(0)
  total    Int @default(0)

  // isReceived triggers INBOUND StockMovement for PRODUCT lines
  isReceived Boolean   @default(false)
  receivedAt DateTime?

  supplierId Int
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines    PurchaseLine[]
  payments PurchasePayment[]

  @@unique([id, organizationId])
  @@index([supplierId])
  @@index([organizationId])
  @@index([status])
}

model PurchaseLine {
  id       Int @id @default(autoincrement())
  quantity Int
  // Cost at time of purchase — snapshot
  unitCost Int
  taxAmt   Int @default(0)
  total    Int

  purchaseOrderId Int
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  ItemId Int
  Item   Item @relation(fields: [ItemId], references: [id])

  // Quantity actually received (for partial receipts)
  receivedQty Int @default(0)

  @@index([purchaseOrderId])
  @@index([ItemId])
}

model PurchasePayment {
  id        Int           @id @default(autoincrement())
  amount    Int
  method    PaymentMethod @default(TRANSFER)
  date      DateTime      @default(now())
  reference String?
  notes     String?

  purchaseOrderId Int
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([purchaseOrderId])
}

enum JobStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

// ============================================================
// Contracts  (CRM — customer agreements, renewals)
// ============================================================

model Contract {
  id          String  @id @default(uuid())
  title       String
  description String?
  isActive    Boolean @default(true)

  contractValue Int? // In smallest currency unit
  currency      String @default("BHD")

  startDate        DateTime
  endDate          DateTime
  renewalDate      DateTime?
  // Days before endDate to trigger renewal alert
  renewalAlertDays Int       @default(30)

  version Int @default(1)

  // Optional customer link
  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id])

  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([isActive])
  @@index([endDate])
  @@index([customerId])
}
